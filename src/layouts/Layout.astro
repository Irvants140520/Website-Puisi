---
const {
  title       = 'Ruang Ivans — Sebuah Ruang Puisi & Perenungan',
  description = 'Ruang Ivans — sebuah ruang puisi, perenungan, dan kata-kata yang lahir dalam keheningan. Karya Chao Ivans.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0a090c" />
  <title>{title}</title>

  <!-- Branded favicon (inline SVG — no extra request) -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%230a090c'/%3E%3Ccircle cx='16' cy='16' r='5' fill='%23c69470'/%3E%3C/svg%3E" />

  <!-- Open Graph / Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:site_name" content="Ruang Ivans" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preconnect" href="https://unpkg.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..600&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Motion libraries — deferred so they don't block parsing -->
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/typeit@8.8.3/dist/index.umd.min.js"></script>
  <script is:inline defer src="https://unpkg.com/split-type@0.3.4/umd/index.min.js"></script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/lenis@1.1.13/dist/lenis.min.js"></script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* ── Modern editorial palette: deep ink + warm ivory + muted copper ── */
      --ink-deep:    #060509;
      --ink:         #0a090c;
      --ink-soft:    #131218;
      --ink-raised:  #181722;
      --ink-line:    #20202a;
      --ink-mute:    #1a1a23;

      --paper:       #f1ebe0;     /* warm ivory text */
      --paper-mid:   #b9b1a3;
      --paper-dim:   #7c766c;
      --paper-ghost: #4d4842;
      --paper-faint: #2a2722;

      --copper:        #c69470;   /* dusty warm copper accent */
      --copper-bright: #e0a983;
      --copper-soft:   #8e6346;
      --copper-dim:    #5e4129;
      --copper-glow:   rgba(198, 148, 112, 0.10);
      --copper-faint:  rgba(198, 148, 112, 0.04);

      /* Backwards-compatible aliases (so admin / slug pages still work) */
      --noir:        var(--ink);
      --noir-deep:   var(--ink-deep);
      --ombre:       var(--ink-soft);
      --bistre:      var(--ink-soft);
      --raised:      var(--ink-raised);
      --sepia:       var(--ink-line);
      --sepia-soft:  var(--ink-mute);
      --ivory:       var(--paper);
      --ivory-dim:   var(--paper-mid);
      --ivory-mid:   var(--paper-dim);
      --ivory-ghost: var(--paper-ghost);
      --ivory-faint: var(--paper-faint);
      --gilt:        var(--copper);
      --gilt-bright: var(--copper-bright);
      --gilt-soft:   var(--copper-soft);
      --gilt-deep:   var(--copper-dim);
      --gilt-glow:   var(--copper-glow);
      --gilt-faint:  var(--copper-faint);
      --vermillion:  #8b3a2a;
      --vermillion-deep: #5d2418;
      --verdigris:   #4a5d4a;
      --vellum:      var(--paper);
      --vellum-mid:  var(--paper-mid);
      --vellum-dim:  var(--paper-mid);
      --vellum-ghost:var(--paper-ghost);
      --gold:        var(--copper);
      --gold-bright: var(--copper-bright);
      --gold-soft:   var(--copper-soft);
      --ink-line:    var(--ink-line);

      /* Typography */
      --display:     'Fraunces', 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
      --serif:       'EB Garamond', 'Fraunces', Georgia, serif;
      --ui:          'Inter', system-ui, sans-serif;
      --engrave:     'Inter', 'Cinzel', sans-serif;
      --mono:        'Inter', system-ui, sans-serif;
      --script:      'Pinyon Script', cursive;
      --hand:        'Fraunces', serif;

      --measure:     62ch;
      --ease-poetic: cubic-bezier(0.22, 1, 0.36, 1);
      --ease-sostenuto: cubic-bezier(0.65, 0, 0.35, 1);
      --ease-quill:  cubic-bezier(0.32, 0.04, 0.18, 1);
    }

    html {
      background: var(--ink);
      color-scheme: dark;
    }
    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto !important; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }

    body {
      background:
        radial-gradient(ellipse 1100px 700px at 50% -8%, rgba(198,148,112,0.07), transparent 60%),
        radial-gradient(ellipse 800px 500px at 90% 110%, rgba(120,90,70,0.05), transparent 60%),
        var(--ink);
      color: var(--paper);
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      line-height: 1.7;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
      overflow-x: hidden;
      /* Smooth page entry — fades in once fonts are ready */
      opacity: 0;
      transition: opacity 0.45s ease-out;
    }
    body.is-ready { opacity: 1; }
    @media (prefers-reduced-motion: reduce) {
      body { opacity: 1; transition: none; }
    }

    /* Very subtle film grain — barely perceptible */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 9998;
      pointer-events: none;
      opacity: 0.035;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.85 0 0 0 0 0.78 0 0 0 0 0.65 0 0 0 0.6 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    /* Soft vignette */
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 9997;
      pointer-events: none;
      background:
        radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.45) 100%);
    }

    ::selection { background: var(--copper); color: var(--ink); }

    a { color: inherit; text-decoration: none; }
    button { font: inherit; color: inherit; background: none; border: none; cursor: pointer; }
    img { max-width: 100%; display: block; }

    ::-webkit-scrollbar { width: 0px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: transparent; }

    /* ── Reusable engraved label ── */
    .engraved {
      font-family: var(--ui);
      font-weight: 500;
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.32em;
      color: var(--copper);
    }

    .ink-stroke {
      stroke: var(--copper);
      stroke-width: 1;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    /* ── Cursor-tracking warm glow (used on hero / pages opting in) ── */
    .cursor-glow {
      position: fixed;
      top: 0; left: 0;
      width: 600px; height: 600px;
      border-radius: 50%;
      pointer-events: none;
      z-index: 1;
      background: radial-gradient(circle, rgba(198,148,112,0.10), rgba(198,148,112,0.04) 35%, transparent 70%);
      filter: blur(20px);
      transform: translate(-50%, -50%);
      opacity: 0;
      transition: opacity 1.4s ease;
      will-change: transform, opacity;
      mix-blend-mode: screen;
    }
    .cursor-glow.is-on { opacity: 1; }

    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.001ms !important;
        transition-duration: 0.001ms !important;
      }
      .cursor-glow { display: none; }
    }
  </style>
</head>
<body>
  <!-- Cursor-following warm glow -->
  <div class="cursor-glow" id="cursor-glow" aria-hidden="true"></div>

  <slot />

  <!-- Page reveal: fade body in only once fonts are ready (no FOUC / no swap flash) -->
  <script is:inline>
    (function () {
      var revealed = false;
      function reveal () {
        if (revealed) return;
        revealed = true;
        document.body.classList.add('is-ready');
      }
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function () {
          requestAnimationFrame(reveal);
        });
      }
      // Hard fallback so we never get stuck invisible
      setTimeout(reveal, 1100);
    })();
  </script>

  <!-- Lenis smooth scroll + GSAP integration -->
  <script is:inline>
    (() => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      const initLenis = () => {
        if (!window.Lenis || !window.gsap) return;

        const lenis = new window.Lenis({
          duration: 1.15,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 1.4,
        });

        if (window.ScrollTrigger) {
          window.gsap.registerPlugin(window.ScrollTrigger);
          lenis.on('scroll', window.ScrollTrigger.update);
          window.gsap.ticker.add((time) => lenis.raf(time * 1000));
          window.gsap.ticker.lagSmoothing(0);
        } else {
          function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
          requestAnimationFrame(raf);
        }

        window.__lenis = lenis;
      };

      const setupCursorGlow = () => {
        const glow = document.getElementById('cursor-glow');
        if (!glow) return;
        // Skip on touch devices — cursor glow only for fine pointers
        if (window.matchMedia('(pointer: coarse)').matches) return;

        let tx = window.innerWidth / 2, ty = window.innerHeight / 2;
        let cx = tx, cy = ty;
        let armed = false;

        window.addEventListener('mousemove', (e) => {
          tx = e.clientX; ty = e.clientY;
          if (!armed) { armed = true; glow.classList.add('is-on'); }
        }, { passive: true });

        function tick() {
          cx += (tx - cx) * 0.08;
          cy += (ty - cy) * 0.08;
          glow.style.transform = `translate(${cx - 300}px, ${cy - 300}px)`;
          requestAnimationFrame(tick);
        }
        tick();
      };

      const onReady = () => {
        initLenis();
        setupCursorGlow();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', onReady);
      } else {
        onReady();
      }
    })();
  </script>
</body>
</html>
