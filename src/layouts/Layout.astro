---
const {
  title       = 'Chao Ivans',
  description = 'Kumpulan Unek-unek Chao Ivans.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Inconsolata:wght@300;400&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:         #090909;
      --ink-card:    #101010;
      --ink-raised:  #161616;
      --ink-line:    #202020;
      --fog:         #ede9e3;
      --fog-dim:     #837f79;
      --fog-ghost:   #3d3a36;
      --teal:        #00d4b8;
      --teal-soft:   #00a896;
      --teal-glow:   rgba(0,212,184,0.10);
      --teal-faint:  rgba(0,212,184,0.04);
      --display:     'Playfair Display', 'Times New Roman', serif;
      --serif:       'EB Garamond', Georgia, serif;
      --mono:        'Inconsolata', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--ink);
      color: var(--fog);
      font-family: var(--serif);
      font-size: 17px;
      line-height: 1.8;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    ::selection { background: var(--teal); color: var(--ink); }
    a { color: inherit; text-decoration: none; }

    ::-webkit-scrollbar { width: 3px; }
    ::-webkit-scrollbar-track { background: var(--ink); }
    ::-webkit-scrollbar-thumb { background: var(--ink-line); }
    ::-webkit-scrollbar-thumb:hover { background: var(--teal-soft); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; } to { opacity: 1; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
