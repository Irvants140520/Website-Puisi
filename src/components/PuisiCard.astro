---
const { puisi, index = 0 } = Astro.props;

function formatTgl(str) {
  return new Date(str).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
}

const lines = (puisi.isi || '').trim().split('\n').filter(l => l.trim()).slice(0, 4);
const num = String(index + 1).padStart(2, '0');
---

<article class="card" data-card data-card-index={index}>
  <a href={`/puisi/${puisi.slug}`} class="frame" aria-label={`Baca puisi: ${puisi.judul}`}>

    <!-- Top accent line that grows on hover -->
    <span class="accent" aria-hidden="true"></span>

    <!-- Top meta: number + date -->
    <div class="meta-top">
      <span class="folio">№&thinsp;{num}</span>
      <span class="date">{formatTgl(puisi.tanggal)}</span>
    </div>

    <!-- Title -->
    <h2 class="title">{puisi.judul}</h2>

    <!-- Excerpt -->
    {lines.length > 0 && (
      <div class="excerpt" aria-hidden="true">
        {lines.map((l, i) => (
          <span class="ex-line" style={`--i:${i}`}>{l}</span>
        ))}
        <span class="ex-fade" aria-hidden="true"></span>
      </div>
    )}

    <!-- Bottom CTA -->
    <div class="foot">
      <span class="cta">
        <span class="cta-label">baca puisi</span>
        <span class="cta-arr" aria-hidden="true">
          <svg viewBox="0 0 28 8">
            <path d="M0 4 H 24 M 21 1 L 24 4 L 21 7" stroke="currentColor" stroke-width="1.1" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
    </div>

  </a>
</article>

<style>
  .card {
    position: relative;
    display: block;
    isolation: isolate;
  }

  .frame {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-align: left;
    gap: 1.2rem;
    padding: 2.1rem 1.7rem 1.5rem;
    height: 100%;
    min-height: 320px;
    background: linear-gradient(180deg,
      rgba(198,148,112,0.025),
      rgba(255,255,255,0) 45%);
    border: 1px solid rgba(255,255,255,0.04);
    transition:
      transform 0.7s var(--ease-poetic),
      border-color 0.5s ease,
      background 0.5s ease,
      box-shadow 0.7s var(--ease-poetic);
    overflow: hidden;
  }

  /* Top accent line */
  .accent {
    position: absolute;
    top: 0; left: 0;
    height: 1px;
    width: 0;
    background: linear-gradient(90deg, var(--copper-bright), var(--copper-soft));
    transition: width 0.85s var(--ease-poetic);
    z-index: 2;
  }

  /* Hover */
  .card:hover .frame {
    transform: translateY(-4px);
    border-color: rgba(198,148,112,0.18);
    background: linear-gradient(180deg,
      rgba(198,148,112,0.05),
      rgba(255,255,255,0) 55%);
    box-shadow:
      0 24px 60px -28px rgba(0,0,0,0.7),
      0 0 0 1px rgba(198,148,112,0.04);
  }
  .card:hover .accent { width: 100%; }

  /* ── Meta top ─────────────────────────────── */
  .meta-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--paper-ghost);
  }
  .folio {
    font-family: var(--ui);
    font-weight: 500;
    font-size: 0.6rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--copper);
    opacity: 0.85;
  }
  .date {
    font-family: var(--ui);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--paper-ghost);
  }

  /* ── Title ────────────────────────────────── */
  .title {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(1.45rem, 2.6vw, 1.7rem);
    line-height: 1.18;
    color: var(--paper);
    letter-spacing: -0.012em;
    transition: color 0.5s ease;
    font-feature-settings: "ss01";
  }
  .card:hover .title { color: var(--copper-bright); }

  /* ── Excerpt ──────────────────────────────── */
  .excerpt {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    max-height: 7.4em;
    overflow: hidden;
    margin-top: -0.2rem;
  }
  .ex-line {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.96rem;
    color: var(--paper-mid);
    opacity: calc(0.95 - var(--i) * 0.13);
    line-height: 1.7;
  }
  .ex-fade {
    position: absolute;
    inset: auto 0 0 0;
    height: 2.4em;
    background: linear-gradient(to bottom, transparent, var(--ink));
    pointer-events: none;
  }

  /* ── Foot CTA ─────────────────────────────── */
  .foot {
    margin-top: auto;
    display: flex;
    justify-content: flex-start;
    padding-top: 0.6rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--paper-dim);
    transition: color 0.5s ease, gap 0.55s var(--ease-poetic);
  }
  .cta-label {
    font-family: var(--ui);
    font-weight: 500;
    font-size: 0.6rem;
    letter-spacing: 0.32em;
    text-indent: 0.32em;
    text-transform: uppercase;
  }
  .cta-arr {
    display: inline-flex;
    width: 28px; height: 8px;
    color: var(--copper);
  }
  .cta-arr svg { width: 100%; height: 100%; display: block; }
  .card:hover .cta { color: var(--paper); gap: 0.95rem; }
</style>
