---
// `currentPath` is accepted for back-compat but auto-detected from the URL
// so /puisi/* highlights "Karya" and 404 / admin don't wrongly highlight "Beranda".
const pathname = Astro.url.pathname;

const links = [
  { href: '/',        label: 'Beranda'  },
  { href: '/semua',   label: 'Karya'    },
  { href: '/tentang', label: 'Tentang'  },
];

const isActive = (href) => {
  if (href === '/')        return pathname === '/';
  if (href === '/semua')   return pathname === '/semua' || pathname.startsWith('/puisi');
  if (href === '/tentang') return pathname === '/tentang';
  return pathname === href;
};
---

<header class="header" id="site-header">
  <div class="inner">

    <a href="/" class="brand" aria-label="Ruang Ivans — beranda">
      <span class="brand-dot" aria-hidden="true"></span>
      <span class="brand-name">Ruang Ivans</span>
    </a>

    <nav class="nav" aria-label="Navigasi utama">
      {links.map((link) => (
        <a href={link.href} class:list={['link', { active: isActive(link.href) }]}>
          {link.label}
        </a>
      ))}
    </nav>

  </div>

  <span class="progress" aria-hidden="true"><span id="progress-bar"></span></span>
</header>

<script is:inline>
  (() => {
    const header = document.getElementById('site-header');
    const bar = document.getElementById('progress-bar');
    if (!header) return;

    let last = 0;
    const onScroll = () => {
      const y = window.scrollY;
      header.classList.toggle('is-scrolled', y > 12);
      if (y > 220 && y > last + 4) header.classList.add('is-hidden');
      else if (y < last - 2 || y < 120) header.classList.remove('is-hidden');
      last = y;

      if (bar) {
        const max = (document.documentElement.scrollHeight - window.innerHeight) || 1;
        bar.style.transform = `scaleX(${Math.min(1, Math.max(0, y / max))})`;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>

<style>
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    transition:
      transform 0.6s var(--ease-poetic),
      background 0.4s ease,
      border-color 0.4s ease,
      backdrop-filter 0.4s ease;
    background: rgba(10, 9, 12, 0.62);
    backdrop-filter: blur(8px) saturate(130%);
    -webkit-backdrop-filter: blur(8px) saturate(130%);
    border-bottom: 1px solid rgba(198, 148, 112, 0.05);
  }
  .header.is-scrolled {
    background: rgba(10, 9, 12, 0.85);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid rgba(198, 148, 112, 0.12);
  }
  .header.is-hidden { transform: translateY(-110%); }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.05rem 1.6rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  /* ── Brand ── */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--paper);
    transition: opacity 0.3s ease;
  }
  .brand:hover { opacity: 0.78; }
  .brand-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--copper);
    box-shadow: 0 0 10px rgba(198,148,112,0.5);
    animation: brandBlink 3.6s ease-in-out infinite;
  }
  @keyframes brandBlink {
    0%, 100% { opacity: 0.95; }
    50%      { opacity: 0.45; }
  }
  .brand-name {
    font-family: var(--display);
    font-weight: 400;
    font-size: 1.05rem;
    letter-spacing: -0.005em;
    color: var(--paper);
  }

  /* ── Nav ── */
  .nav {
    display: inline-flex;
    align-items: center;
    gap: 1.6rem;
  }
  .link {
    position: relative;
    font-family: var(--ui);
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-indent: 0.28em;
    text-transform: uppercase;
    color: var(--paper-mid);
    padding: 0.4rem 0;
    transition: color 0.3s ease;
  }
  .link::after {
    content: '';
    position: absolute;
    left: 50%; right: 50%; bottom: 0;
    height: 1px;
    background: var(--copper);
    transition:
      left 0.45s var(--ease-poetic),
      right 0.45s var(--ease-poetic),
      opacity 0.3s ease;
    opacity: 0;
  }
  .link:hover { color: var(--paper); }
  .link:hover::after { left: 0; right: 0; opacity: 0.55; }
  .link.active { color: var(--paper); }
  .link.active::after { left: 0; right: 0; opacity: 1; }

  /* ── Progress bar ── */
  .progress {
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 1px;
    background: rgba(198,148,112,0.06);
    overflow: hidden;
  }
  .progress > span {
    display: block;
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, var(--copper-soft), var(--copper-bright), var(--copper-soft));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.1s linear;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .inner { padding: 0.8rem 1rem; gap: 0.6rem; }
    .brand { gap: 0.5rem; min-width: 0; flex-shrink: 1; }
    .brand-dot { width: 6px; height: 6px; }
    .brand-name { font-size: 0.92rem; white-space: nowrap; }
    .nav { gap: 0.95rem; flex-shrink: 0; }
    .link { font-size: 0.58rem; letter-spacing: 0.2em; text-indent: 0.2em; padding: 0.35rem 0; }
  }
  @media (max-width: 380px) {
    .inner { padding: 0.72rem 0.85rem; gap: 0.45rem; }
    .brand-name { font-size: 0.86rem; }
    .nav { gap: 0.6rem; }
    .link { font-size: 0.52rem; letter-spacing: 0.16em; text-indent: 0.16em; }
  }
</style>
