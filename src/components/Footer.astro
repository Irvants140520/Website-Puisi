---
const year = new Date().getFullYear();
const startYear = 2019;
---

<footer class="footer">
  <div class="inner">

    <span class="rule" aria-hidden="true"></span>

    <div class="row">
      <div class="brand">
        <span class="dot" aria-hidden="true"></span>
        <span class="name">Ruang Ivans</span>
      </div>

      <nav class="nav" aria-label="Navigasi tambahan">
        <a href="/">Beranda</a>
        <a href="/semua">Karya</a>
        <a href="/tentang">Tentang</a>
      </nav>

      <p class="meta">
        <em>Chao Ivans</em>
        <span>{startYear}&thinsp;—&thinsp;{year}</span>
      </p>
    </div>

    <p class="whisper">
      Ditulis dalam keheningan, untuk dibaca secara perlahan.
    </p>

  </div>
</footer>

<style>
  .footer {
    padding: 5rem 1.5rem 2.4rem;
    margin-top: 4rem;
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
  }

  .rule {
    display: block;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg,
      transparent,
      rgba(198,148,112,0.22) 50%,
      transparent);
  }

  .row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.4rem;
    align-items: center;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    justify-self: start;
  }
  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--copper);
    box-shadow: 0 0 10px rgba(198,148,112,0.5);
  }
  .name {
    font-family: var(--display);
    font-weight: 400;
    font-size: 1rem;
    color: var(--paper);
  }

  .nav {
    display: inline-flex;
    align-items: center;
    gap: 1.6rem;
    justify-self: center;
    font-family: var(--ui);
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-indent: 0.28em;
    text-transform: uppercase;
    color: var(--paper-dim);
  }
  .nav a {
    transition: color 0.3s ease;
    padding: 0.3rem 0;
  }
  .nav a:hover { color: var(--copper-bright); }

  .meta {
    justify-self: end;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    color: var(--paper-mid);
  }
  .meta em {
    font-family: var(--display);
    font-style: italic;
    font-size: 1rem;
    color: var(--paper);
    line-height: 1;
  }
  .meta span {
    font-family: var(--ui);
    font-size: 0.55rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--copper);
    opacity: 0.78;
  }

  .whisper {
    text-align: center;
    font-family: var(--display);
    font-style: italic;
    font-weight: 350;
    font-size: 0.88rem;
    color: var(--paper-ghost);
    line-height: 1.7;
    max-width: 48ch;
    margin: 0 auto;
  }

  @media (max-width: 720px) {
    .footer { padding: 3.5rem 1.2rem 2rem; margin-top: 3rem; }
    .row { grid-template-columns: 1fr; gap: 1.2rem; text-align: center; }
    .brand, .nav, .meta { justify-self: center; }
    .meta { align-items: center; }
    .nav { gap: 1.1rem; flex-wrap: wrap; justify-content: center; }
    .whisper { font-size: 0.82rem; }
  }
</style>
