---
import Layout    from '../layouts/Layout.astro';
import Header    from '../components/Header.astro';
import PuisiCard from '../components/PuisiCard.astro';
import Footer    from '../components/Footer.astro';
import { getAllPuisi } from '../lib/supabase.js';

const semua   = await getAllPuisi();
const terbaru = semua.slice(0, 3);
---

<Layout title="Chao Ivans">
  <div class="page">
    <Header currentPath="/" />
    <main>

      <!-- HERO -->
      <section class="hero" id="hero">

        <!-- ambient glow orb -->
        <div class="glow-orb" aria-hidden="true"></div>

        <div class="hero-inner">

          <div class="eyebrow">
            <span class="e-line"></span>
            <span class="e-text">Ruang</span>
            <span class="e-line"></span>
          </div>

          <!-- Split text untuk stagger animation -->
          <h1 class="hero-name" data-split-text>
            <span class="word"><span class="char">C</span><span class="char">h</span><span class="char">a</span><span class="char">o</span></span>
            <span class="word"><span class="char">I</span><span class="char">v</span><span class="char">a</span><span class="char">n</span><span class="char">s</span></span>
          </h1>

          <blockquote class="hero-verse" data-split-lines>
            <p class="line">aku menulis bukan karena aku paham.</p>
            <p class="line v2">aku menulis untuk melihat dimana aku salah.</p>
          </blockquote>

          <a href="/semua" class="btn" data-fade-up>Jelajahi Karya Tulisku</a>

          <!-- ornamen bawah hero -->
          <div class="hero-ornament" aria-hidden="true" data-parallax="0.5">
            <span class="orn-line"></span>
            <span class="orn-dot"></span>
            <span class="orn-dot"></span>
            <span class="orn-dot"></span>
            <span class="orn-line"></span>
          </div>

        </div>

        <div class="deco" aria-hidden="true" data-parallax="0.2">P · U · I · S · I</div>
      </section>

      <!-- TERBARU -->
      {semua.length > 0 && (
        <section class="section">
          <div class="section-inner">
            <div class="sec-head">
              <h2 class="sec-title">Karya Terbaru</h2>
              <a href="/semua" class="sec-more">Semua →</a>
            </div>
            <div class="grid" id="karya-grid">
              {terbaru.map((p, i) => (
                <div class="card-wrapper" data-card-index={i} data-directional-reveal>
                  <PuisiCard puisi={p} index={i} />
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {semua.length === 0 && (
        <section class="section">
          <div class="section-inner">
            <p class="empty">Belum ada puisi. Tambahkan lewat Supabase.</p>
          </div>
        </section>
      )}

    </main>
    <Footer />
  </div>
</Layout>

<!-- ─── SCROLL & ANIMATION ENGINE ─────────────────────────── -->
<script is:inline>
(function() {
  'use strict';
  
  const nextFrame = () => new Promise(r => requestAnimationFrame(r));
  
  async function initAnimations() {
    console.log('[Chao] Animations start');
    
    /* ─── 1. HERO NAME: Blur Stagger ─── */
    const chars = document.querySelectorAll('.hero-name .char');
    console.log('[Chao] Chars found:', chars.length);
    
    if (chars.length) {
      // Sembunyikan dulu semua
      chars.forEach(c => c.classList.add('char-hidden'));
      
      // FORCE REFLOW: tunggu 2 frame agar browser "menyadari" state awal
      await nextFrame();
      await nextFrame();
      
      // Reveal satu per satu
      chars.forEach((c, i) => {
        const delay = 400 + (i * 250); // 90ms antar huruf, lebih terasa
        setTimeout(() => {
          c.classList.remove('char-hidden');
          c.classList.add('char-revealed');
        }, delay);
      });
    }
    
    /* ─── 2. HERO LINES ─── */
    const lines = document.querySelectorAll('.hero-verse .line');
    lines.forEach(l => l.classList.add('line-hidden'));
    await nextFrame();
    
    lines.forEach((l, i) => {
      setTimeout(() => {
        l.classList.remove('line-hidden');
        l.classList.add('line-revealed');
      }, 1000 + (i * 950));
    });
    
    /* ─── 3. EYEBROW ─── */
    document.querySelectorAll('.e-line').forEach((el, i) => {
      setTimeout(() => el.classList.add('e-line-expanded'), 700 + (i * 300));
    });
    
    /* ─── 4. CTA BUTTON ─── */
    const btn = document.querySelector('.btn');
    if (btn) {
      btn.classList.add('btn-hidden');
      await nextFrame();
      setTimeout(() => {
        btn.classList.remove('btn-hidden');
        btn.classList.add('btn-revealed');
      }, 1700);
    }
    
    /* ─── 5. PARALLAX SCROLL ─── */
    const hero = document.getElementById('hero');
    const parallaxEls = document.querySelectorAll('[data-parallax]');
    let ticking = false;
    
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY;
          if (hero) {
            const inner = hero.querySelector('.hero-inner');
            const orb = hero.querySelector('.glow-orb');
            if (inner) inner.style.transform = `translateY(${y * 0.12}px)`;
            if (orb) orb.style.transform = `translateY(${y * -0.06}px)`;
          }
          parallaxEls.forEach(el => {
            const s = parseFloat(el.dataset.parallax) || 0;
            const r = el.getBoundingClientRect();
            const d = (window.innerHeight/2 - (r.top + r.height/2)) * s * 0.08;
            el.style.transform = `translateY(${d}px)`;
          });
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
    
    /* ─── 6. DIRECTIONAL CARD REVEAL ─── */
    const grid = document.getElementById('karya-grid');
    if (grid) {
      const wrappers = grid.querySelectorAll('.card-wrapper');
      
      const getDir = (idx) => {
        if (window.innerWidth >= 900) {
          const m = idx % 3;
          if (m === 0) return 'translate(-50px, 30px) rotate(-2deg)';
          if (m === 2) return 'translate(50px, 30px) rotate(2deg)';
          return 'translate(0, 45px)';
        }
        if (window.innerWidth >= 640) {
          return idx % 2 === 0 
            ? 'translate(-35px, 30px) rotate(-1.5deg)' 
            : 'translate(35px, 30px) rotate(1.5deg)';
        }
        return 'translate(0, 35px)';
      };
      
      // Set state awal
      wrappers.forEach((w, i) => {
        const card = w.firstElementChild;
        if (!card) return;
        card.style.opacity = '0';
        card.style.filter = 'blur(10px)';
        card.style.transform = getDir(i);
        card.style.transition = 'none';
      });
      
      await nextFrame();
      
      // Pasang transition
      wrappers.forEach((w) => {
        const card = w.firstElementChild;
        if (card) {
          card.style.transition = 'opacity 0.7s cubic-bezier(.4,0,.2,1), transform 0.7s cubic-bezier(.4,0,.2,1), filter 0.9s cubic-bezier(.4,0,.2,1)';
        }
      });
      
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const w = e.target;
            const idx = parseInt(w.dataset.cardIndex || 0);
            const card = w.firstElementChild;
            setTimeout(() => {
              if (card) {
                card.style.opacity = '1';
                card.style.filter = 'blur(0px)';
                card.style.transform = 'translate(0,0) rotate(0deg)';
              }
            }, idx * 200);
            io.unobserve(w);
          }
        });
      }, { threshold: 0, rootMargin: '0px 0px -50px 0px' });
      
      wrappers.forEach(w => io.observe(w));
    }
    
    console.log('[Chao] Animations complete');
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimations);
  } else {
    initAnimations();
  }
})();
</script>

<style>
  /* ═══════════════════════════════════════════
     BASE (sama seperti sebelumnya)
     ═══════════════════════════════════════════ */
  .page { display:flex; flex-direction:column; min-height:100vh; }
  main  { flex:1; }

  .page::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    opacity: 0.035;
    pointer-events: none;
    z-index: 999;
    animation: grainShift 0.5s steps(2) infinite;
  }
  @keyframes grainShift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-1px, 1px); }
  }

  /* ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    padding: 5rem 1.5rem 3.5rem;
    overflow: hidden;
  }

  .glow-orb {
    position: absolute;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,184,.06) 0%, transparent 68%);
    top: -80px;
    right: -80px;
    pointer-events: none;
    will-change: transform;
  }

  .hero-inner {
    max-width: 860px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    will-change: transform;
  }

  /* Eyebrow */
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .e-line {
    height: 1px;
    background: var(--teal);
    opacity: .5;
    width: 0;
    transition: width 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .e-line-expanded { width: 36px; }
  
  .e-text {
    font-family: var(--mono);
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .25em;
    color: var(--teal);
    opacity: .8;
  }

  /* Hero Name — EFEK DRAMATIS DI SINI */
  .hero-name {
    font-family: var(--display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -.02em;
    color: var(--fog);
    margin-bottom: 2rem;
  }
  .hero-name .word {
    display: inline-block;
    margin-right: 0.3em;
    white-space: nowrap;
  }
  .hero-name .char {
    display: inline-block;
    will-change: transform, filter, opacity;
    /* Easing lebih "dramatic" */
    transition:
      opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      color 0.6s ease;
  }
  /* State awal: blur tebal, geser besar, warna hilang */
  .hero-name .char-hidden {
    opacity: 0;
    filter: blur(20px) brightness(2.5);
    transform: translateY(50px) scale(0.75);
    color: transparent;
  }
  /* State akhir */
  .hero-name .char-revealed {
    opacity: 1;
    filter: blur(0px) brightness(1);
    transform: translateY(0) scale(1);
    color: var(--fog);
  }

  /* Hero Verse */
  .hero-verse {
    position: relative;
    margin-bottom: 2.5rem;
    padding-left: 1.25rem;
    font-style: normal;
  }
  .hero-verse::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 2px;
    height: 0;
    background: var(--teal);
    animation: drawBorder 0.7s 0.9s cubic-bezier(.4, 0, .2, 1) forwards;
  }
  @keyframes drawBorder {
    to { height: 100%; }
  }
  .hero-verse .line {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1rem, 3vw, 1.2rem);
    color: var(--fog-dim);
    line-height: 1.9;
    will-change: transform, filter, opacity;
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-verse .line-hidden {
    opacity: 0;
    filter: blur(12px);
    transform: translateY(30px);
  }
  .hero-verse .line-revealed {
    opacity: 1;
    filter: blur(0px);
    transform: translateY(0);
  }
  .hero-verse .v2 { color: var(--fog); }

  /* CTA */
  .btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .15em;
    color: var(--fog);
    border: 1px solid var(--ink-line);
    padding: .65rem 1.4rem;
    border-radius: 3px;
    transition:
      opacity 0.6s ease,
      transform 0.6s ease,
      border-color .25s,
      color .25s,
      background .25s;
  }
  .btn-hidden {
    opacity: 0;
    transform: translateY(20px);
  }
  .btn-revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .btn:hover {
    border-color: var(--teal-soft);
    color: var(--teal);
    background: var(--teal-faint);
  }

  /* Ornament */
  .hero-ornament {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-top: 2.2rem;
    will-change: transform;
  }
  .orn-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ink-line) 40%, var(--ink-line) 60%, transparent);
  }
  .orn-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--teal);
    opacity: .35;
    animation: dotPulse 3.5s ease-in-out infinite;
  }
  .orn-dot:nth-child(3) { animation-delay: .55s; }
  .orn-dot:nth-child(4) { animation-delay: 1.1s; }
  @keyframes dotPulse {
    0%, 100% { opacity: .2; transform: scale(1); }
    50%       { opacity: .65; transform: scale(1.6); }
  }

  /* Deco */
  .deco {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%) rotate(90deg);
    font-family: var(--mono);
    font-size: .55rem;
    letter-spacing: .4em;
    color: var(--ink-raised);
    pointer-events: none;
    will-change: transform;
  }
  @media(max-width: 600px) { .deco { display: none; } }

  /* ═══════════════════════════════════════════
     SECTION & GRID
     ═══════════════════════════════════════════ */
  .section { padding: 3rem 1.5rem 4rem; }
  .section-inner { max-width: 860px; margin: 0 auto; }

  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--ink-line);
  }
  .sec-title {
    font-family: var(--display);
    font-size: 1.15rem;
    font-weight: 400;
    font-style: italic;
    color: var(--fog);
  }
  .sec-more {
    font-family: var(--mono);
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--fog-dim);
    transition: color .2s;
  }
  .sec-more:hover { color: var(--teal); }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--ink-line);
    border: 1px solid var(--ink-line);
    border-radius: 4px;
    overflow: hidden;
  }
  .card-wrapper {
    position: relative;
    transition: background .25s ease;
  }
  .card-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--teal);
    transition: width .35s cubic-bezier(.4, 0, .2, 1);
    z-index: 2;
  }
  .card-wrapper:hover::before { width: 100%; }
  .card-wrapper:hover { background: rgba(0, 212, 184, 0.03); }
  
  @media(min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media(min-width: 900px) { .grid { grid-template-columns: repeat(3, 1fr); } }

  .empty {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fog-ghost);
    text-align: center;
    padding: 3rem 0;
  }

  /* Keyframes */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
