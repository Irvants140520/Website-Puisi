---
import Layout    from '../layouts/Layout.astro';
import Header    from '../components/Header.astro';
import PuisiCard from '../components/PuisiCard.astro';
import Footer    from '../components/Footer.astro';
import { getAllPuisi } from '../lib/supabase.js';

const semua    = await getAllPuisi();
const featured = semua[0] ?? null;
const terbaru  = semua.slice(0, 6);

function formatTgl(str) {
  return new Date(str).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
}

const marqueeWords = [
  'diam', 'tinta', 'sunyi', 'lembaran', 'ruang',
  'bernafas', 'kata', 'jeda', 'tertulis', 'perlahan',
  'cermin', 'hujan', 'malam', 'mendengar',
];
---

<Layout title="Ruang Ivans — Sebuah Ruang Puisi & Perenungan">
  <Header currentPath="/" />

  <main class="page">

    <!-- ════════════════════════════════════════════════════
         I. HERO — Ruang yang Bernafas
    ════════════════════════════════════════════════════ -->
    <section class="hero" id="hero" aria-label="Pembukaan">

      <!-- Breathing aurora -->
      <div class="aurora" aria-hidden="true">
        <span class="blob a1"></span>
        <span class="blob a2"></span>
        <span class="blob a3"></span>
      </div>

      <!-- Floating dust (nafas) -->
      <div class="dust" aria-hidden="true">
        <span style="--x: 8%;  --y: 28%; --s: 3px; --d: 0s;"></span>
        <span style="--x: 18%; --y: 70%; --s: 2px; --d: 1.4s;"></span>
        <span style="--x: 32%; --y: 18%; --s: 2px; --d: 2.6s;"></span>
        <span style="--x: 47%; --y: 82%; --s: 3px; --d: 0.8s;"></span>
        <span style="--x: 62%; --y: 42%; --s: 2px; --d: 3.2s;"></span>
        <span style="--x: 76%; --y: 22%; --s: 2px; --d: 1.9s;"></span>
        <span style="--x: 88%; --y: 64%; --s: 3px; --d: 2.2s;"></span>
        <span style="--x: 93%; --y: 36%; --s: 2px; --d: 0.4s;"></span>
      </div>

      <!-- Top status -->
      <div class="hero-top" data-anim="top">
        <span class="hero-top-dot"></span>
        <span class="hero-top-text">— sebuah ruang untuk perenungan</span>
      </div>

      <!-- Top-right folio mark -->
      <div class="folio-mark" data-anim="folio">
        <span class="fm-no">№ 001</span>
        <span class="fm-line"></span>
        <span class="fm-yr">mmxxvi</span>
      </div>

      <!-- Right rail (manuscript margin) -->
      <aside class="right-rail" aria-hidden="true">
        <span class="rr-tick" data-anim="rail">vol. I</span>
        <span class="rr-line" data-anim="rail-line"></span>
        <span class="rr-tick" data-anim="rail">locus</span>
        <span class="rr-line" data-anim="rail-line"></span>
        <span class="rr-tick" data-anim="rail">poesis</span>
      </aside>

      <!-- Center editorial stage -->
      <div class="hero-stage">

        <!-- Tiny ornament before title -->
        <span class="title-orn" data-anim="orn" aria-hidden="true">+</span>

        <!-- TITLE — mask line reveal -->
        <h1 class="hero-title" id="hero-title">
          <span class="line">
            <span class="line-inner">Ruang</span>
          </span>
          <span class="line italic">
            <span class="line-inner">Ivans</span>
          </span>
        </h1>

        <!-- Hand-drawn flourish under title -->
        <svg class="title-flourish" viewBox="0 0 400 12" aria-hidden="true">
          <path d="M2 6 Q 100 1, 200 6 T 398 6"
                stroke="currentColor" stroke-width="1.1"
                fill="none" stroke-linecap="round"/>
        </svg>

        <!-- QUOTE — line-by-line mask reveal -->
        <blockquote class="hero-quote">
          <span class="q-mark" data-anim="qmark" aria-hidden="true">❋</span>

          <span class="q-line">
            <span class="q-line-inner">
              Aku menulis bukan karena aku paham,
            </span>
          </span>
          <span class="q-line">
            <span class="q-line-inner italic">
              Aku menulis untuk melihat <em class="q-em">dimana aku salah.</em>
            </span>
          </span>

          <!-- Drawn ink stroke under "dimana aku salah" -->
          <svg class="quote-stroke" viewBox="0 0 280 14" aria-hidden="true">
            <path d="M4 8 Q 70 2, 140 7 T 276 6"
                  stroke="currentColor" stroke-width="1.6"
                  fill="none" stroke-linecap="round"/>
          </svg>
        </blockquote>

        <!-- CTA — single primary action -->
        <div class="hero-cta" data-anim="cta">
          <a href="/semua" class="btn-primary">
            <span class="bp-text">Jelajahi Karyaku</span>
            <span class="bp-arr" aria-hidden="true">
              <svg viewBox="0 0 28 8"><path d="M0 4 H 24 M 21 1 L 24 4 L 21 7" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        </div>

      </div>

      <!-- Bottom-left signature -->
      <div class="hero-sig" data-anim="sig">
        <span class="sig-line"></span>
        <span class="sig-text"><em>chao ivans</em> — sejak 2019</span>
      </div>

      <!-- Scroll cue -->
      <div class="scroll-cue" data-anim="cue" aria-hidden="true">
        <span class="cue-text">scroll</span>
        <span class="cue-line"><span></span></span>
      </div>

    </section>

    <!-- ════════════════════════════════════════════════════
         I.b  Kinetic word strip (transition)
    ════════════════════════════════════════════════════ -->
    <section class="marquee" aria-hidden="true">
      <div class="m-track" id="m-track">
        {[...marqueeWords, ...marqueeWords, ...marqueeWords].map((w, i) => (
          <span class:list={['m-word', { accent: i % 4 === 1 }]}>
            {w}<span class="m-dot">·</span>
          </span>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════
         II. MANIFESTO — pinned scrollytelling with peeking numerals
    ════════════════════════════════════════════════════ -->
    <section class="manifesto" id="manifesto" aria-label="Tiga gerakan perenungan">
      <div class="man-pin">

        <!-- Massive peeking numerals on left edge -->
        <div class="man-numerals" aria-hidden="true">
          <span class="num-glyph num-1 active">1</span>
          <span class="num-glyph num-2">2</span>
          <span class="num-glyph num-3">3</span>
        </div>

        <!-- Subtle dust in pinned scene -->
        <div class="man-dust" aria-hidden="true">
          <span style="--x: 22%; --y: 24%; --d: 0s;"></span>
          <span style="--x: 41%; --y: 76%; --d: 1.6s;"></span>
          <span style="--x: 68%; --y: 30%; --d: 2.8s;"></span>
          <span style="--x: 86%; --y: 60%; --d: 1.2s;"></span>
        </div>

        <!-- Top progress -->
        <div class="man-progress" aria-hidden="true">
          <span class="mp-num">01</span>
          <span class="mp-bar"><span id="mp-fill"></span></span>
          <span class="mp-num">03</span>
        </div>

        <!-- Center stage -->
        <div class="man-stage">

          <article class="leaf is-active" data-leaf="0">
            <p class="leaf-marker"><span class="lm-rom">i.</span> <em>perlahan</em></p>
            <blockquote class="leaf-text">
              Aku menulis dalam diam,<br/>
              <em>untuk menemukan hal-hal yang tak sempat terucap.</em>
            </blockquote>
            <p class="leaf-cite"><span class="lc-line"></span> dari sebuah catatan kecil</p>
          </article>

          <article class="leaf" data-leaf="1">
            <p class="leaf-marker"><span class="lm-rom">ii.</span> <em>tenang</em></p>
            <blockquote class="leaf-text">
              Setiap baris adalah jendela kecil,<br/>
              <em>tempat hujan dan ingatan saling bertukar tempat.</em>
            </blockquote>
            <p class="leaf-cite"><span class="lc-line"></span> dari ruang yang basah</p>
          </article>

          <article class="leaf" data-leaf="2">
            <p class="leaf-marker"><span class="lm-rom">iii.</span> <em>ingatan</em></p>
            <blockquote class="leaf-text">
              Antara aku, kamu dan pena,<br/>
              <em>mengenang kenangan indah</em>
            </blockquote>
            <p class="leaf-cite"><span class="lc-line"></span> di ambang malam</p>
          </article>

        </div>

        <!-- Right-side marginalia notes -->
        <aside class="man-margin" aria-hidden="true">
          <span class="mm-note active" data-mm="0">
            <span class="mm-tick">—</span> pukul 02:00 pagi
          </span>
          <span class="mm-note" data-mm="1">
            <span class="mm-tick">—</span> hujan bulan juni
          </span>
          <span class="mm-note" data-mm="2">
            <span class="mm-tick">—</span> di ambang malam
          </span>
        </aside>

      </div>
    </section>

    {featured && (
      <!-- ════════════════════════════════════════════════════
           III. KARYA PILIHAN
      ════════════════════════════════════════════════════ -->
      <section class="featured" aria-label="Karya Pilihan">
        <div class="feat-inner">

          <header class="feat-head">
            <span class="feat-label">— karya pilihan</span>
            <span class="feat-no">№&thinsp;01</span>
          </header>

          <article class="feat-card">

            <div class="feat-meta">
              <span class="feat-date">{formatTgl(featured.tanggal)}</span>
              <span class="feat-tag">unggulan</span>
            </div>

            <h2 class="feat-title">{featured.judul}</h2>

            {featured.pengantar && (
              <p class="feat-pengantar"><em>“{featured.pengantar}”</em></p>
            )}

            <div class="feat-excerpt">
              {featured.isi.trim().split('\n').filter(l => l.trim()).slice(0, 5).map(l => (
                <span class="feat-line">{l}</span>
              ))}
            </div>

            <a href={`/puisi/${featured.slug}`} class="feat-cta">
              <span>baca puisi ini</span>
              <span aria-hidden="true">
                <svg viewBox="0 0 28 8" width="28" height="8"><path d="M0 4 H 24 M 21 1 L 24 4 L 21 7" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>

          </article>

        </div>
      </section>
    )}

    {semua.length > 0 ? (
      <!-- ════════════════════════════════════════════════════
           IV. LEMBARAN TERBARU
      ════════════════════════════════════════════════════ -->
      <section class="works" aria-label="Karya Terbaru">
        <div class="works-inner">

          <header class="works-head">
            <div class="works-titles">
              <span class="works-label">— lembaran terbaru</span>
              <h2 class="works-title">
                <span class="wt-row">Karya yang</span>
                <span class="wt-row italic">baru tertulis</span>
              </h2>
            </div>
            <a href="/semua" class="works-all">
              <span>seluruh karya</span>
              <svg viewBox="0 0 28 8" width="28" height="8"><path d="M0 4 H 24 M 21 1 L 24 4 L 21 7" stroke="currentColor" stroke-width="1.1" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </header>

          <div class="works-grid" id="works-grid">
            {terbaru.map((p, i) => (
              <div class="works-cell" data-cell-index={i}>
                <PuisiCard puisi={p} index={i} />
              </div>
            ))}
          </div>

        </div>
      </section>
    ) : (
      <section class="works">
        <div class="works-inner">
          <p class="empty">
            <span class="empty-orn">∽</span>
            <span class="empty-text">Lembaran masih kosong. Puisi pertama akan segera tertulis.</span>
          </p>
        </div>
      </section>
    )}

    <!-- ════════════════════════════════════════════════════
         V. PENUTUP
    ════════════════════════════════════════════════════ -->
    <section class="outro" aria-label="Penutup">
      <div class="outro-inner">
        <p class="outro-line" data-anim="outro">
          Sebuah tulisan memang tidak bisa mengubah
          <br/> apa yang sudah terjadi,<br/>
          <em>namun ia mengingat segalanya...</em>
        </p>
        <span class="outro-rule" aria-hidden="true"></span>
        <span class="outro-sig">— Chao Ivans</span>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<!-- ════════════════════════════════════════════════════════
     ANIMATION ENGINE
════════════════════════════════════════════════════════ -->
<script is:inline>
(function () {
  'use strict';

  const ready = () => new Promise(r => {
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', r);
    else r();
  });

  ready().then(init).catch(err => console.error('[hero]', err));

  function init () {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!window.gsap) return;
    const gsap = window.gsap;
    if (window.ScrollTrigger) gsap.registerPlugin(window.ScrollTrigger);

    /* ═══ 1. Prepare drawn SVG paths ═══ */
    const prepPath = (sel) => {
      const p = document.querySelector(sel);
      if (!p) return null;
      const len = p.getTotalLength();
      gsap.set(p, { strokeDasharray: len, strokeDashoffset: len });
      return p;
    };
    const titleFlourish = prepPath('.title-flourish path');
    const quoteStroke   = prepPath('.quote-stroke path');

    /* ═══ 2. Set initial state of mask reveals ═══ */
    gsap.set('.line-inner, .q-line-inner', { yPercent: 110 });

    /* ═══ 3. Opening sequence ═══ */
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    /* Top elements */
    tl.from('[data-anim="top"] .hero-top-dot',  { scale: 0, transformOrigin: 'center', duration: 0.6, ease: 'back.out(1.6)' }, 0)
      .from('[data-anim="top"] .hero-top-text', { opacity: 0, x: -8, duration: 0.7 }, 0.1);

    tl.from('[data-anim="folio"] > *', {
      opacity: 0, x: 10, duration: 0.7, stagger: 0.06
    }, 0.2);

    /* Right rail */
    tl.from('[data-anim="rail-line"]', { scaleY: 0, transformOrigin: 'top', stagger: 0.15, duration: 1.0, ease: 'power2.out' }, 0.3)
      .from('[data-anim="rail"]',      { opacity: 0, x: 8, stagger: 0.08, duration: 0.7 }, 0.45);

    /* Title ornament */
    tl.from('[data-anim="orn"]', { opacity: 0, rotate: -90, scale: 0.5, duration: 0.8, ease: 'back.out(1.4)' }, 0.5);

    /* TITLE mask reveal */
    tl.to('.line-inner', {
      yPercent: 0, stagger: 0.14, duration: 1.3, ease: 'expo.out'
    }, 0.55);

    /* Title flourish draws */
    if (titleFlourish) {
      tl.to(titleFlourish, { strokeDashoffset: 0, duration: 1.3, ease: 'power2.inOut' }, 1.3);
    }

    /* Quote mark */
    tl.from('[data-anim="qmark"]', { opacity: 0, scale: 0.4, rotate: -45, duration: 0.7, ease: 'back.out(1.6)' }, 1.55);

    /* QUOTE lines mask reveal */
    tl.to('.q-line-inner', {
      yPercent: 0, stagger: 0.18, duration: 1.2, ease: 'expo.out'
    }, 1.7);

    /* Quote stroke draws under "salah" */
    if (quoteStroke) {
      tl.to(quoteStroke, { strokeDashoffset: 0, duration: 1.2, ease: 'power2.inOut' }, 2.7);
    }

    /* CTAs + bottom */
    tl.from('[data-anim="cta"] > *', { opacity: 0, y: 14, duration: 0.85, stagger: 0.12 }, 3.0)
      .from('[data-anim="sig"] .sig-line', { scaleX: 0, transformOrigin: 'left', duration: 1.0 }, 3.3)
      .from('[data-anim="sig"] .sig-text', { opacity: 0, x: -8, duration: 0.8 }, 3.5)
      .from('[data-anim="cue"]',           { opacity: 0, y: 8,  duration: 0.85 }, 3.5);

    /* ═══ 4. Continuous breathing — aurora ═══ */
    if (!reduced) {
      gsap.to('.a1', { x: 60,  y: -30, scale: 1.06, duration: 11, repeat: -1, yoyo: true, ease: 'sine.inOut' });
      gsap.to('.a2', { x: -50, y: 40,  scale: 1.04, duration: 13, repeat: -1, yoyo: true, ease: 'sine.inOut' });
      gsap.to('.a3', { x: 30,  y: 20,  scale: 1.08, duration: 16, repeat: -1, yoyo: true, ease: 'sine.inOut' });

      /* Floating dust */
      gsap.utils.toArray('.dust > span, .man-dust > span').forEach((d) => {
        const dx = (Math.random() - 0.5) * 30;
        const dy = -15 - Math.random() * 30;
        const dur = 6 + Math.random() * 6;
        gsap.to(d, {
          x: dx, y: dy,
          opacity: 0.15 + Math.random() * 0.35,
          duration: dur, repeat: -1, yoyo: true, ease: 'sine.inOut'
        });
      });

      /* Mouse parallax on title (subtle) */
      const titleEl = document.querySelector('.hero-title');
      const stageEl = document.querySelector('.hero-stage');
      if (titleEl && stageEl) {
        let mx = 0, my = 0, cx = 0, cy = 0;
        window.addEventListener('mousemove', (e) => {
          mx = (e.clientX / window.innerWidth - 0.5) * 14;
          my = (e.clientY / window.innerHeight - 0.5) * 8;
        }, { passive: true });
        function loop() {
          cx += (mx - cx) * 0.05;
          cy += (my - cy) * 0.05;
          titleEl.style.transform = `translate(${-cx}px, ${-cy}px)`;
          requestAnimationFrame(loop);
        }
        loop();
      }
    }

    if (!window.ScrollTrigger) return;
    const ScrollTrigger = window.ScrollTrigger;

    /* ═══ 5. Hero parallax on scroll ═══ */
    gsap.to('.hero-stage', {
      y: 80, opacity: 0.4, ease: 'none',
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
    });
    gsap.to('.aurora', {
      y: -50, ease: 'none',
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
    });

    /* ═══ 6. MANIFESTO — pinned ═══ */
    const leaves   = gsap.utils.toArray('.leaf');
    const numerals = gsap.utils.toArray('.num-glyph');
    const margins  = gsap.utils.toArray('.mm-note');
    const fill     = document.getElementById('mp-fill');
    const pinPanel = document.querySelector('.man-pin');

    const bgs = [
      'radial-gradient(ellipse 80% 60% at 30% 50%, rgba(198,148,112,0.10), transparent 60%), var(--ink)',
      'radial-gradient(ellipse 80% 60% at 50% 50%, rgba(110,120,170,0.10), transparent 60%), var(--ink)',
      'radial-gradient(ellipse 80% 60% at 70% 50%, rgba(180,120,90,0.12), transparent 60%), var(--ink)',
    ];

    /* Initial state for leaves & numerals */
    gsap.set(leaves.slice(1), { opacity: 0, y: 40, filter: 'blur(8px)' });
    gsap.set(numerals.slice(1), { opacity: 0, x: -120 });
    gsap.set(margins.slice(1), { opacity: 0 });

    let lastActive = 0;

    ScrollTrigger.create({
      trigger: '.manifesto',
      start: 'top top',
      end: '+=160%',
      pin: '.man-pin',
      scrub: 0.4,
      onUpdate: (self) => {
        const p = self.progress;
        let active = 0;
        if (p > 0.62) active = 2;
        else if (p > 0.30) active = 1;

        if (active !== lastActive) {
          leaves.forEach((el, i) => {
            gsap.to(el, {
              opacity: i === active ? 1 : 0,
              y: i === active ? 0 : (i < active ? -40 : 40),
              filter: i === active ? 'blur(0px)' : 'blur(8px)',
              duration: 0.8, ease: 'power2.out', overwrite: 'auto'
            });
            el.classList.toggle('is-active', i === active);
          });
          numerals.forEach((g, i) => {
            gsap.to(g, {
              opacity: i === active ? 1 : 0,
              x: i === active ? 0 : (i < active ? -120 : 120),
              duration: 0.9, ease: 'power3.out', overwrite: 'auto'
            });
            g.classList.toggle('active', i === active);
          });
          margins.forEach((m, i) => {
            gsap.to(m, {
              opacity: i === active ? 0.85 : 0,
              y: i === active ? 0 : 10,
              duration: 0.7, ease: 'power2.out', overwrite: 'auto'
            });
            m.classList.toggle('active', i === active);
          });
          if (pinPanel) pinPanel.style.background = bgs[active];
          lastActive = active;
        }

        if (fill) fill.style.transform = `scaleX(${p})`;
      }
    });

    /* ═══ 7. FEATURED ═══ */
    if (document.querySelector('.feat-card')) {
      gsap.from('.feat-head > *', {
        opacity: 0, y: 18, duration: 1, stagger: 0.08, ease: 'power3.out',
        scrollTrigger: { trigger: '.featured', start: 'top 75%' }
      });
      gsap.from('.feat-card > *', {
        opacity: 0, y: 26, duration: 1.1, stagger: 0.09, ease: 'power3.out',
        scrollTrigger: { trigger: '.feat-card', start: 'top 78%' }
      });
      gsap.from('.feat-line', {
        opacity: 0, y: 14, duration: 0.8, stagger: 0.06, ease: 'power3.out',
        scrollTrigger: { trigger: '.feat-excerpt', start: 'top 85%' }
      });
    }

    /* ═══ 8. WORKS ═══ */
    gsap.from('.works-titles > *', {
      opacity: 0, y: 24, duration: 1.1, stagger: 0.1, ease: 'power3.out',
      scrollTrigger: { trigger: '.works-head', start: 'top 80%' }
    });
    gsap.from('.works-all', {
      opacity: 0, x: 16, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: '.works-head', start: 'top 80%' }
    });
    const cells = gsap.utils.toArray('.works-cell');
    cells.forEach((cell, i) => {
      gsap.from(cell, {
        opacity: 0, y: 36, filter: 'blur(6px)',
        duration: 1.1, ease: 'power3.out', delay: (i % 3) * 0.08,
        scrollTrigger: { trigger: cell, start: 'top 88%' }
      });
    });

    /* ═══ 9. OUTRO ═══ */
    if (window.SplitType) {
      const lineEl = document.querySelector('[data-anim="outro"]');
      if (lineEl) {
        const split = new window.SplitType(lineEl, { types: 'words' });
        gsap.set(split.words, { opacity: 0.18 });
        gsap.to(split.words, {
          opacity: 1,
          stagger: 0.05, duration: 0.6, ease: 'power2.out',
          scrollTrigger: { trigger: '.outro', start: 'top 75%', end: 'top 30%', scrub: 1 }
        });
      }
    }
    gsap.from('.outro-rule', {
      scaleX: 0, transformOrigin: 'center', duration: 1.2, ease: 'power3.out',
      scrollTrigger: { trigger: '.outro', start: 'top 65%' }
    });
    gsap.from('.outro-sig', {
      opacity: 0, y: 14, duration: 1.1, ease: 'power3.out',
      scrollTrigger: { trigger: '.outro', start: 'top 65%' }
    });

    /* ═══ 10. SECTION SNAP — full-screen feel ═══ */
    const isCoarse = window.matchMedia('(pointer: coarse)').matches;
    const isNarrow = window.matchMedia('(max-width: 820px)').matches;
    if (!reduced && !isCoarse && !isNarrow && window.ScrollTrigger) {
      const ST = window.ScrollTrigger;
      const snapSelectors = ['#hero', '.manifesto', '.featured', '.works', '.outro'];

      const getSectionSnaps = () => {
        const max = ST.maxScroll(window);
        if (max <= 0) return [0, 1];
        const points = new Set([0, 1]);
        snapSelectors.forEach(sel => {
          const el = document.querySelector(sel);
          if (!el) return;
          const top = el.getBoundingClientRect().top + window.scrollY;
          points.add(Math.max(0, Math.min(0.999, top / max)));
        });
        // After manifesto pin (= start of featured visually)
        const m = document.querySelector('.manifesto');
        if (m) {
          const top = m.getBoundingClientRect().top + window.scrollY;
          const end = top + window.innerHeight * 1.6;
          points.add(Math.max(0, Math.min(0.999, end / max)));
        }
        return Array.from(points).sort((a, b) => a - b);
      };

      ST.create({
        start: 0,
        end: 'max',
        snap: {
          snapTo: (value) => {
            const max = ST.maxScroll(window);
            const currentScroll = value * max;
            // Skip snap inside manifesto pin (let scrub handle stage transitions)
            const m = document.querySelector('.manifesto');
            if (m) {
              const top = m.getBoundingClientRect().top + window.scrollY;
              const vh = window.innerHeight;
              if (currentScroll > top + 0.08 * vh && currentScroll < top + 1.52 * vh) {
                return value;
              }
            }
            const points = getSectionSnaps();
            return points.reduce((p, c) =>
              Math.abs(c - value) < Math.abs(p - value) ? c : p
            );
          },
          duration: { min: 0.25, max: 0.7 },
          delay: 0.14,
          ease: 'power3.inOut',
          inertia: false
        }
      });
    }
  }
})();
</script>

