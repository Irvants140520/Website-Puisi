---
import Layout    from '../layouts/Layout.astro';
import Header    from '../components/Header.astro';
import PuisiCard from '../components/PuisiCard.astro';
import Footer    from '../components/Footer.astro';
import { getAllPuisi } from '../lib/supabase.js';

const semua   = await getAllPuisi();
const terbaru = semua.slice(0, 3);
---

<Layout title="Chao Ivans">
  <div class="page">
    <Header currentPath="/" />
    <main>

      <!-- HERO -->
      <section class="hero">

        <!-- ambient glow orb -->
        <div class="glow-orb" aria-hidden="true"></div>

        <div class="hero-inner">

          <div class="eyebrow">
            <span class="e-line"></span>
            <span class="e-text">Ruang</span>
            <span class="e-line"></span>
          </div>

          <h1 class="hero-name">Chao Ivans</h1>

          <blockquote class="hero-verse">
            <p>aku menulis bukan karena aku paham.</p>
            <p class="v2">aku menulis untuk melihat dimana aku salah.</p>
          </blockquote>

          <a href="/semua" class="btn">Jelajahi Karya Tulisku</a>

          <!-- ornamen bawah hero, mengisi ruang kosong -->
          <div class="hero-ornament" aria-hidden="true">
            <span class="orn-line"></span>
            <span class="orn-dot"></span>
            <span class="orn-dot"></span>
            <span class="orn-dot"></span>
            <span class="orn-line"></span>
          </div>

        </div>

        <div class="deco" aria-hidden="true">P · U · I · S · I</div>
      </section>

      <!-- TERBARU -->
      {semua.length > 0 && (
        <section class="section">
          <div class="section-inner">
            <div class="sec-head">
              <h2 class="sec-title">Karya Terbaru</h2>
              <a href="/semua" class="sec-more">Semua →</a>
            </div>
            <div class="grid" id="karya-grid">
              {terbaru.map((p, i) => <PuisiCard puisi={p} index={i} />)}
            </div>
          </div>
        </section>
      )}

      {semua.length === 0 && (
        <section class="section">
          <div class="section-inner">
            <p class="empty">Belum ada puisi. Tambahkan lewat Supabase.</p>
          </div>
        </section>
      )}

    </main>
    <Footer />
  </div>
</Layout>

<!-- ─── SCROLL REVEAL ─────────────────────────────────────── -->
<script>
  const grid = document.getElementById('karya-grid');
  if (grid) {
    const cards = Array.from(grid.children) as HTMLElement[];

    // State awal — turun + sedikit mengecil
    cards.forEach((card) => {
      card.style.opacity   = '0';
      card.style.transform = 'translateY(28px) scale(0.97)';
      card.style.transition = 'none'; // cegah flash saat set
    });

    // Tunggu satu frame baru pasang transition
    requestAnimationFrame(() => {
      cards.forEach((card, i) => {
        card.style.transition =
          `opacity .6s ${i * 0.13}s cubic-bezier(.4,0,.2,1),
           transform .6s ${i * 0.13}s cubic-bezier(.4,0,.2,1)`;
      });
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const card = entry.target as HTMLElement;
            card.style.opacity   = '1';
            card.style.transform = 'translateY(0) scale(1)';
            io.unobserve(card);
          }
        });
      },
      // threshold 0 = segera begitu 1px masuk viewport
      // rootMargin negatif = baru trigger saat card 40px masuk layar
      { threshold: 0, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((c) => io.observe(c));
  }
</script>

</script>

<style>
  /* ── BASE ─────────────────────────────────── */
  .page { display:flex; flex-direction:column; min-height:100vh; }
  main  { flex:1; }

  /* Grain overlay — analog warmth */
  .page::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    opacity: 0.035;
    pointer-events: none;
    z-index: 999;
  }

  /* ── HERO ─────────────────────────────────── */
  .hero {
    position: relative;
    padding: 5rem 1.5rem 3.5rem; /* bawah dikurangi */
    overflow: hidden;
  }

  /* Ambient glow orb — drift pelan */
  .glow-orb {
    position: absolute;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,184,.06) 0%, transparent 68%);
    top: -80px;
    right: -80px;
    pointer-events: none;
    animation: orbDrift 16s ease-in-out infinite alternate;
  }
  @keyframes orbDrift {
    from { transform: translate(0, 0) scale(1);        opacity: .7; }
    to   { transform: translate(-32px, 40px) scale(1.1); opacity: 1; }
  }

  .hero-inner {
    max-width: 860px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Eyebrow */
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp .6s .1s ease forwards;
  }
  /* e-line melebar dari 0 */
  .e-line {
    height: 1px;
    width: 0;
    background: var(--teal);
    opacity: .5;
    animation: expandLine .8s .7s ease forwards;
  }
  @keyframes expandLine {
    to { width: 36px; }
  }
  .e-text {
    font-family: var(--mono);
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .25em;
    color: var(--teal);
    opacity: .8;
  }

  /* Hero name */
  .hero-name {
    font-family: var(--display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -.02em;
    color: var(--fog);
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp .7s .2s ease forwards;
  }

  /* Verse — border kiri "tumbuh" dari atas ke bawah */
  .hero-verse {
    position: relative;
    margin-bottom: 2.5rem;
    padding-left: 1.25rem;
    font-style: normal;
    opacity: 0;
    animation: fadeUp .7s .35s ease forwards;
  }
  .hero-verse::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 2px;
    height: 0;
    background: var(--teal);
    animation: drawBorder .7s .9s cubic-bezier(.4, 0, .2, 1) forwards;
  }
  @keyframes drawBorder {
    to { height: 100%; }
  }
  .hero-verse p {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1rem, 3vw, 1.2rem);
    color: var(--fog-dim);
    line-height: 1.9;
  }
  .hero-verse .v2 { color: var(--fog); }

  /* CTA Button */
  .btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .15em;
    color: var(--fog);
    border: 1px solid var(--ink-line);
    padding: .65rem 1.4rem;
    border-radius: 3px;
    transition: border-color .25s, color .25s, background .25s;
    opacity: 0;
    animation: fadeUp .6s .5s ease forwards;
  }
  .btn:hover {
    border-color: var(--teal-soft);
    color: var(--teal);
    background: var(--teal-faint);
  }

  /* Ornamen bawah hero — tiga titik pulsing */
  .hero-ornament {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-top: 2.2rem;
    opacity: 0;
    animation: fadeIn .8s 1s ease forwards;
  }
  .orn-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--ink-line) 40%,
      var(--ink-line) 60%,
      transparent
    );
  }
  .orn-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--teal);
    opacity: .35;
    animation: dotPulse 3.5s ease-in-out infinite;
  }
  .orn-dot:nth-child(3) { animation-delay: .55s; }
  .orn-dot:nth-child(4) { animation-delay: 1.1s;  }
  @keyframes dotPulse {
    0%, 100% { opacity: .2;  transform: scale(1);    }
    50%       { opacity: .65; transform: scale(1.6);  }
  }

  /* Deco samping */
  .deco {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%) rotate(90deg);
    font-family: var(--mono);
    font-size: .55rem;
    letter-spacing: .4em;
    color: var(--ink-raised);
    pointer-events: none;
    opacity: 0;
    animation: fadeIn 1.2s .8s ease forwards;
  }
  @media(max-width: 600px) { .deco { display: none; } }

  /* ── SECTION ──────────────────────────────── */
  .section { padding: 3rem 1.5rem 4rem; }
  .section-inner { max-width: 860px; margin: 0 auto; }

  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--ink-line);
  }
  .sec-title {
    font-family: var(--display);
    font-size: 1.15rem;
    font-weight: 400;
    font-style: italic;
    color: var(--fog);
  }
  .sec-more {
    font-family: var(--mono);
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--fog-dim);
    transition: color .2s;
  }
  .sec-more:hover { color: var(--teal); }

  /* Grid */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--ink-line);
    border: 1px solid var(--ink-line);
    border-radius: 4px;
    overflow: hidden;
  }
  
  .grid > * {
    position: relative;
    transition: background .25s ease;
  }

  /* Garis teal di atas card — "meluncur" dari kiri ke kanan saat hover */
  .grid > *::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--teal);
    transition: width .35s cubic-bezier(.4, 0, .2, 1);
    z-index: 2;
  }
  .grid > *:hover::before {
    width: 100%;
  }

  /* Subtle background lift saat hover */
  .grid > *:hover {
    background: rgba(0, 212, 184, 0.03);
  }
  
  @media(min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media(min-width: 900px) { .grid { grid-template-columns: repeat(3, 1fr); } }

  .empty {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fog-ghost);
    text-align: center;
    padding: 3rem 0;
  }

  /* ── KEYFRAMES ────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0);    }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
