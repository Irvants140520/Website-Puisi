---
import Layout   from '../layouts/Layout.astro';
import Header   from '../components/Header.astro';
import PuisiCard from '../components/PuisiCard.astro';
import Footer   from '../components/Footer.astro';
import { getAllPuisi } from '../lib/supabase.js';

const semua   = await getAllPuisi();
const terbaru = semua.slice(0, 3);
---

<Layout title="Chao Ivans — Karya Puisi">
  <div class="page">
    <Header currentPath="/" />
    <main>

      <!-- HERO -->
      <section class="hero">
        <div class="hero-inner">
          <div class="eyebrow">
            <span class="e-line"></span>
            <span class="e-text">Puisi</span>
            <span class="e-line"></span>
          </div>
          <h1 class="hero-name">Chao Ivans</h1>
          <blockquote class="hero-verse">
            <p>Membaca untuk mengenal dunia</p>
            <p class="v2">Dan menulis untuk dikenal dunia.</p>
          </blockquote>
          <a href="/semua" class="btn">Jelajahi Karya</a>
        </div>
        <div class="deco" aria-hidden="true">P · U · I · S · I</div>
      </section>

      <!-- TERBARU -->
      {semua.length > 0 && (
        <section class="section">
          <div class="section-inner">
            <div class="sec-head">
              <h2 class="sec-title">Karya Terbaru</h2>
              <a href="/semua" class="sec-more">Semua →</a>
            </div>
            <div class="grid">
              {terbaru.map((p, i) => <PuisiCard puisi={p} index={i} />)}
            </div>
          </div>
        </section>
      )}

      {semua.length === 0 && (
        <section class="section">
          <div class="section-inner">
            <p class="empty">Belum ada puisi. Tambahkan lewat Supabase.</p>
          </div>
        </section>
      )}

    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { display:flex; flex-direction:column; min-height:100vh; }
  main  { flex:1; }

  /* HERO */
  .hero { position:relative; padding:5.5rem 1.5rem 5rem; overflow:hidden; }
  .hero-inner { max-width:860px; margin:0 auto; position:relative; z-index:1; }

  .eyebrow { display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; opacity:0; animation:fadeUp .6s .1s ease forwards; }
  .e-line  { height:1px; width:36px; background:var(--teal); opacity:.5; }
  .e-text  { font-family:var(--mono); font-size:.65rem; text-transform:uppercase; letter-spacing:.25em; color:var(--teal); opacity:.8; }

  .hero-name { font-family:var(--display); font-size:clamp(3rem,10vw,6rem); font-weight:400; line-height:1.05; letter-spacing:-.02em; color:var(--fog); margin-bottom:2rem; opacity:0; animation:fadeUp .7s .2s ease forwards; }

  .hero-verse { margin-bottom:2.5rem; padding-left:1.25rem; border-left:2px solid rgba(0,212,184,.3); opacity:0; animation:fadeUp .7s .35s ease forwards; font-style:normal; }
  .hero-verse p { font-family:var(--serif); font-style:italic; font-size:clamp(1rem,3vw,1.2rem); color:var(--fog-dim); line-height:1.9; }
  .hero-verse .v2 { color:var(--fog); }

  .btn { display:inline-block; font-family:var(--mono); font-size:.7rem; text-transform:uppercase; letter-spacing:.15em; color:var(--fog); border:1px solid var(--ink-line); padding:.65rem 1.4rem; border-radius:3px; transition:border-color .25s,color .25s,background .25s; opacity:0; animation:fadeUp .6s .5s ease forwards; }
  .btn:hover { border-color:var(--teal-soft); color:var(--teal); background:var(--teal-faint); }

  .deco { position:absolute; right:1.5rem; top:50%; transform:translateY(-50%) rotate(90deg); font-family:var(--mono); font-size:.55rem; letter-spacing:.4em; color:var(--ink-raised); pointer-events:none; opacity:0; animation:fadeIn 1.2s .8s ease forwards; }
  @media(max-width:600px){.deco{display:none}}

  /* SECTION */
  .section { padding:3rem 1.5rem 4rem; }
  .section-inner { max-width:860px; margin:0 auto; }
  .sec-head { display:flex; align-items:baseline; justify-content:space-between; margin-bottom:2rem; padding-bottom:1rem; border-bottom:1px solid var(--ink-line); }
  .sec-title { font-family:var(--display); font-size:1.15rem; font-weight:400; font-style:italic; color:var(--fog); }
  .sec-more  { font-family:var(--mono); font-size:.62rem; text-transform:uppercase; letter-spacing:.1em; color:var(--fog-dim); transition:color .2s; }
  .sec-more:hover { color:var(--teal); }

  .grid { display:grid; grid-template-columns:1fr; gap:1px; background:var(--ink-line); border:1px solid var(--ink-line); border-radius:4px; overflow:hidden; }
  @media(min-width:640px){ .grid{grid-template-columns:repeat(2,1fr)} }
  @media(min-width:900px){ .grid{grid-template-columns:repeat(3,1fr)} }

  .empty { font-family:var(--serif); font-style:italic; color:var(--fog-ghost); text-align:center; padding:3rem 0; }
</style>
