---
import Layout  from '../../layouts/Layout.astro';
import Header  from '../../components/Header.astro';
import Footer  from '../../components/Footer.astro';
import { getPuisiBySlug, getAllPuisi, tambahView } from '../../lib/supabase.js';

const { slug } = Astro.params;
const puisi    = await getPuisiBySlug(slug);

if (!puisi) return Astro.redirect('/404');

await tambahView(slug);

const semua = await getAllPuisi();
const idx   = semua.findIndex(p => p.slug === slug);
const prev  = idx < semua.length - 1 ? semua[idx + 1] : null;
const next  = idx > 0                ? semua[idx - 1] : null;

function formatTgl(str) {
  return new Date(str).toLocaleDateString('id-ID', {
    weekday:'long', day:'numeric', month:'long', year:'numeric'
  });
}

const paragraphs = puisi.isi.trim().split(/\n\n+/);
const pageUrl    = Astro.url.href;

const wordCount  = puisi.isi.trim().split(/\s+/).length;
const readMins   = Math.max(1, Math.round(wordCount / 80));
---

<Layout title={`${puisi.judul} — Chao Ivans`} description={puisi.pengantar ?? ''}>

  <!-- Reading progress — glow line -->
  <div class="progress-track" aria-hidden="true">
    <div class="progress-bar" id="progress-bar"></div>
    <div class="progress-glow" id="progress-glow"></div>
  </div>

  <div class="page">
    <Header />
    <main>
      <article class="article" id="article">

        <!-- Ambient glow — drift lebih lambat, lebih besar -->
        <div class="article-glow" aria-hidden="true"></div>
        <div class="article-glow-2" aria-hidden="true"></div>

        <!-- Header — reveal teatrikal -->
        <header class="poem-head" id="poem-head">
          <p class="date" data-reveal="up">{formatTgl(puisi.tanggal)}</p>
          <h1 class="title" data-reveal="blur">{puisi.judul}</h1>
          <p class="read-time" data-reveal="up">{readMins} menit baca</p>
          {puisi.pengantar && <p class="pengantar" data-reveal="fade">{puisi.pengantar}</p>}
        </header>

        <div class="rule" data-reveal="expand">
          <span class="r-line r-left"></span>
          <span class="r-dash">oleh Chao Ivans</span>
          <span class="r-line r-right"></span>
        </div>

        <!-- Body — stanza muncul seperti gelombang -->
        <div class="body" id="poem-body">
          {paragraphs.map((p, i) => (
            <p
              class={`stanza${i === 0 ? ' stanza-first' : ''}`}
              data-stanza={i}
              data-reveal="stanza"
            >
              {p}
            </p>
          ))}
        </div>

        <!-- End mark — fade in terpisah -->
        <div class="end-mark" data-reveal="up">
          <span class="end-dash">—</span>
          <span class="end-views">𓁹 {puisi.views ?? 0} kali dibaca</span>
        </div>

        <!-- Share — slide up -->
        <div class="share" data-reveal="up">
          <p class="share-label">Bagikan puisi ini</p>
          <div class="share-row">
            <button class="sbtn" id="btn-native">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Bagikan
            </button>
            <button class="sbtn" id="btn-copy">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012 2v1"/></svg>
              <span id="copy-lbl">Salin Link</span>
            </button>
            <a class="sbtn sbtn-wa" href={`https://wa.me/?text=${encodeURIComponent(`"${puisi.judul}" — Chao Ivans\n${pageUrl}`)}`} target="_blank" rel="noopener">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.138.562 4.144 1.541 5.876L0 24l6.303-1.519A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.671-.497-5.214-1.366l-.374-.219-3.742.902.938-3.651-.24-.386A9.946 9.946 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
              WhatsApp
            </a>
            <a class="sbtn sbtn-tw" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`"${puisi.judul}" — Chao Ivans`)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.629 5.905-5.629zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X / Twitter
            </a>
          </div>
        </div>

        <!-- Nav — parallax subtle -->
        <nav class="pnav" data-reveal="up">
          {prev ? (
            <a href={`/puisi/${prev.slug}`} class="pnav-item pnav-prev">
              <span class="pnav-dir">← Sebelumnya</span>
              <span class="pnav-title">{prev.judul}</span>
            </a>
          ) : <div />}
          <a href="/semua" class="pnav-all">Semua Karya</a>
          {next ? (
            <a href={`/puisi/${next.slug}`} class="pnav-item pnav-next">
              <span class="pnav-dir">Berikutnya →</span>
              <span class="pnav-title">{next.judul}</span>
            </a>
          ) : <div />}
        </nav>

      </article>
    </main>
    <Footer />
  </div>
</Layout>

<!-- ════════════════════════════════════════════════════════
     SCRIPT — Animation Engine
     ════════════════════════════════════════════════════════ -->
<script is:inline>
(function() {
  'use strict';
  
  const nextFrame = () => new Promise(r => requestAnimationFrame(r));
  
  /* ── 1. READING PROGRESS — Glow Line ───────────────── */
  const bar = document.getElementById('progress-bar');
  const glow = document.getElementById('progress-glow');
  
  function updateProgress() {
    const scrolled  = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? (scrolled / docHeight) * 100 : 0;
    
    if (bar) bar.style.width = `${pct}%`;
    if (glow) {
      glow.style.width = `${pct}%`;
      // Glow intensifies saat scroll
      glow.style.opacity = 0.3 + (pct / 200);
    }
  }
  
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  /* ── 2. SCROLL-TRIGGERED REVEAL ENGINE ─────────────── */
  const revealElements = document.querySelectorAll('[data-reveal]');
  
  // Set initial states berdasarkan tipe
  revealElements.forEach(el => {
    const type = el.dataset.reveal;
    el.classList.add(`reveal-${type}-hidden`);
  });
  
  // Force reflow
  nextFrame().then(() => {
    revealElements.forEach(el => {
      const type = el.dataset.reveal;
      // Pasang transition setelah frame stabil
      requestAnimationFrame(() => {
        el.classList.add(`reveal-${type}-ready`);
      });
    });
  });
  
  // IntersectionObserver untuk trigger
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target;
        const type = el.dataset.reveal;
        const delay = parseFloat(el.dataset.delay || 0);
        
        setTimeout(() => {
          el.classList.remove(`reveal-${type}-hidden`);
          el.classList.add(`reveal-${type}-visible`);
        }, delay);
        
        revealObserver.unobserve(el);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
  
  revealElements.forEach(el => revealObserver.observe(el));

  /* ── 3. STANZA WAVE REVEAL ─────────────────────────── */
  const stanzas = document.querySelectorAll('.stanza[data-reveal="stanza"]');
  
  // Stanza punya reveal tersendiri — lebih dramatis
  stanzas.forEach((s, i) => {
    s.style.opacity = '0';
    s.style.transform = 'translateY(35px) scale(0.98)';
    s.style.filter = 'blur(8px)';
    s.style.transition = 'none';
  });
  
  nextFrame().then(() => {
    stanzas.forEach(s => {
      s.style.transition = `
        opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
        transform 1s cubic-bezier(0.22, 1, 0.36, 1),
        filter 1.2s cubic-bezier(0.22, 1, 0.36, 1)
      `;
    });
  });
  
  const stanzaObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target;
        const idx = parseInt(el.dataset.stanza || 0);
        
        // Wave stagger — tiap stanza 180ms lebih lambat
        setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0) scale(1)';
          el.style.filter = 'blur(0px)';
        }, idx * 180);
        
        stanzaObserver.unobserve(el);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -50px 0px' });
  
  stanzas.forEach(s => stanzaObserver.observe(s));

  /* ── 4. PARALLAX AMBIENT GLOWS ─────────────────────── */
  const glow1 = document.querySelector('.article-glow');
  const glow2 = document.querySelector('.article-glow-2');
  let ticking = false;
  
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const y = window.scrollY;
        if (glow1) glow1.style.transform = `translateY(${y * -0.04}px) translateX(${y * 0.02}px)`;
        if (glow2) glow2.style.transform = `translateY(${y * 0.06}px) translateX(${y * -0.03}px)`;
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  /* ── 5. SHARE BUTTONS ──────────────────────────────── */
  const url   = window.location.href;
  const title = document.querySelector('.title')?.textContent || '';

  const btnNative = document.getElementById('btn-native');
  if (navigator.share && btnNative) {
    btnNative.addEventListener('click', () =>
      navigator.share({ title, url }).catch(() => {})
    );
  } else if (btnNative) {
    btnNative.style.display = 'none';
  }

  document.getElementById('btn-copy')?.addEventListener('click', () => {
    navigator.clipboard.writeText(url).then(() => {
      const lbl = document.getElementById('copy-lbl');
      if (lbl) {
        lbl.textContent = 'Tersalin!';
        setTimeout(() => (lbl.textContent = 'Salin Link'), 2000);
      }
    });
  });
})();
</script>

<style>
  /* ════════════════════════════════════════════════════════
     BASE
     ════════════════════════════════════════════════════════ */
  .page { display:flex; flex-direction:column; min-height:100vh; }
  main  { flex:1; }

  /* Grain overlay — konsisten dengan beranda */
  .page::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    opacity: 0.035;
    pointer-events: none;
    z-index: 999;
    animation: grainShift 0.5s steps(2) infinite;
  }
  @keyframes grainShift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-1px, 1px); }
  }

  /* ════════════════════════════════════════════════════════
     PROGRESS BAR — Glow Line
     ════════════════════════════════════════════════════════ */
  .progress-track {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 1000;
    pointer-events: none;
    background: rgba(0, 212, 184, 0.05);
  }
  
  .progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--teal), rgba(0,212,184,.6));
    transition: width 0.15s linear;
  }
  
  .progress-glow {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, transparent, var(--teal), transparent);
    filter: blur(4px);
    opacity: 0.3;
    transition: width 0.15s linear, opacity 0.3s ease;
  }

  /* ════════════════════════════════════════════════════════
     ARTICLE
     ════════════════════════════════════════════════════════ */
  .article {
    position: relative;
    max-width: 580px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
    overflow: hidden;
  }

  /* Dual ambient glow — bergerak berlawanan */
  .article-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,184,.04) 0%, transparent 70%);
    top: -80px;
    right: -150px;
    pointer-events: none;
    will-change: transform;
  }
  
  .article-glow-2 {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,184,.03) 0%, transparent 65%);
    bottom: 20%;
    left: -200px;
    pointer-events: none;
    will-change: transform;
  }

  /* ════════════════════════════════════════════════════════
     POEM HEADER — Reveal States
     ════════════════════════════════════════════════════════ */
  .poem-head { margin-bottom: 2rem; position: relative; z-index: 1; }

  .date {
    font-family: var(--mono);
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--fog-ghost);
    margin-bottom: .75rem;
    display: block;
  }

  /* TITLE — Blur Reveal */
  .title {
    font-family: var(--display);
    font-size: clamp(2rem, 7vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--fog);
    margin-bottom: .5rem;
    will-change: transform, filter, opacity;
  }
  
  .reveal-blur-hidden {
    opacity: 0;
    filter: blur(16px) brightness(2);
    transform: translateY(30px) scale(0.95);
  }
  
  .reveal-blur-ready {
    transition: 
      opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.4s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1s cubic-bezier(0.22, 1, 0.36, 1),
      color 0.6s ease;
  }
  
  .reveal-blur-visible {
    opacity: 1;
    filter: blur(0px) brightness(1);
    transform: translateY(0) scale(1);
  }

  .read-time {
    font-family: var(--mono);
    font-size: .58rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--teal);
    opacity: .45;
    margin-bottom: .9rem;
  }

  .pengantar {
    font-family: var(--serif);
    font-style: italic;
    font-size: .95rem;
    color: var(--fog-dim);
    line-height: 1.7;
    margin-top: .75rem;
  }

  /* ════════════════════════════════════════════════════════
     RULE — Expand dari tengah
     ════════════════════════════════════════════════════════ */
  .rule {
    margin: 1.75rem 0 2rem;
    display: flex;
    align-items: center;
    gap: .75rem;
    position: relative;
    z-index: 1;
  }
  
  .r-line {
    flex: 1;
    height: 1px;
    background: var(--ink-line);
    transform-origin: center;
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  
  .reveal-expand-hidden .r-left { transform: scaleX(0); transform-origin: right; }
  .reveal-expand-hidden .r-right { transform: scaleX(0); transform-origin: left; }
  .reveal-expand-visible .r-left,
  .reveal-expand-visible .r-right { transform: scaleX(1); }
  
  .reveal-expand-hidden .r-dash {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.6s 0.4s ease, transform 0.6s 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-expand-visible .r-dash {
    opacity: 1;
    transform: scale(1);
  }
  
  .r-dash {
    color: var(--teal);
    opacity: 0.15;
    font-size: 1.1rem;
    white-space: nowrap;
  }

  /* ════════════════════════════════════════════════════════
     POEM BODY — Stanza
     ════════════════════════════════════════════════════════ */
  .body {
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }

  /* Drop cap — stanza pertama */
  .stanza-first::first-letter {
    float: left;
    font-family: var(--display);
    font-size: clamp(3rem, 12vw, 4.5rem);
    line-height: 0.8;
    padding-top: 4px;
    padding-right: 10px;
    color: var(--teal);
    text-shadow: 0 0 20px rgba(0,212,184,.15);
  }

  .stanza {
    font-family: var(--serif);
    font-size: 1.15rem;
    line-height: 2.1;
    color: var(--fog);
    white-space: pre-line;
    margin-bottom: 2.5rem;
    letter-spacing: .01em;
    will-change: transform, filter, opacity;
  }
  .stanza:last-child { margin-bottom: 0; }

  /* ════════════════════════════════════════════════════════
     REVEAL UTILITIES — Up & Fade
     ════════════════════════════════════════════════════════ */
  .reveal-up-hidden {
    opacity: 0;
    transform: translateY(25px);
  }
  .reveal-up-ready {
    transition: 
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-up-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-fade-hidden {
    opacity: 0;
  }
  .reveal-fade-ready {
    transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-fade-visible {
    opacity: 1;
  }

  /* ════════════════════════════════════════════════════════
     END MARK
     ════════════════════════════════════════════════════════ */
  .end-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    padding: 2rem 0;
  }
  .end-dash {
    color: var(--teal);
    opacity: .3;
    font-size: 1.2rem;
  }
  .end-views {
    font-family: var(--mono);
    font-size: .58rem;
    letter-spacing: .1em;
    color: var(--fog-dim);
    opacity: .6;
  }

  /* ════════════════════════════════════════════════════════
     SHARE
     ════════════════════════════════════════════════════════ */
  .share {
    border: 1px solid var(--ink-line);
    border-radius: 4px;
    padding: 1.25rem 1.4rem;
    margin-bottom: 2.5rem;
    background: var(--ink-card);
  }
  .share-label {
    font-family: var(--mono);
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .15em;
    color: var(--fog-ghost);
    margin-bottom: .85rem;
  }
  .share-row { display: flex; flex-wrap: wrap; gap: .5rem; }

  .sbtn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-family: var(--mono);
    font-size: .65rem;
    letter-spacing: .08em;
    color: var(--fog-dim);
    background: var(--ink-raised);
    border: 1px solid var(--ink-line);
    border-radius: 3px;
    padding: .4rem .75rem;
    cursor: pointer;
    transition: color .2s, border-color .2s, background .2s, transform .2s;
    text-decoration: none;
  }
  .sbtn:hover {
    color: var(--fog);
    border-color: var(--fog-ghost);
    transform: translateY(-1px);
  }
  .sbtn-wa:hover {
    color: #25d366;
    border-color: rgba(37,211,102,.3);
    background: rgba(37,211,102,.06);
  }
  .sbtn-tw:hover {
    color: #1d9bf0;
    border-color: rgba(29,155,240,.3);
    background: rgba(29,155,240,.06);
  }

  /* ════════════════════════════════════════════════════════
     NAV
     ════════════════════════════════════════════════════════ */
  .pnav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: .75rem;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid var(--ink-line);
  }
  .pnav-item {
    display: flex;
    flex-direction: column;
    gap: .2rem;
    padding: .65rem .75rem;
    border-radius: 3px;
    border: 1px solid transparent;
    transition: border-color .2s, background .2s, transform .2s;
  }
  .pnav-item:hover {
    border-color: var(--ink-line);
    background: var(--ink-card);
    transform: translateY(-2px);
  }
  .pnav-prev { align-items: flex-start; }
  .pnav-next { align-items: flex-end; text-align: right; }
  .pnav-dir {
    font-family: var(--mono);
    font-size: .58rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--teal-soft);
    opacity: .7;
  }
