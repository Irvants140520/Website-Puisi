---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPuisiBySlug, getAllPuisi, tambahView } from '../../lib/supabase.js';

const { slug } = Astro.params;
const puisi    = await getPuisiBySlug(slug);

if (!puisi) return Astro.redirect('/404');

await tambahView(slug);

const semua = await getAllPuisi();
const idx   = semua.findIndex(p => p.slug === slug);
const prev  = idx < semua.length - 1 ? semua[idx + 1] : null;
const next  = idx > 0                ? semua[idx - 1] : null;

function formatTgl(str) {
  return new Date(str).toLocaleDateString('id-ID', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
  });
}

function romanize(num) {
  const lookup = [
    ['M',1000],['CM',900],['D',500],['CD',400],
    ['C',100],['XC',90],['L',50],['XL',40],
    ['X',10],['IX',9],['V',5],['IV',4],['I',1],
  ];
  let n = num + 1, out = '';
  for (const [r, v] of lookup) { while (n >= v) { out += r; n -= v; } }
  return out;
}

const stanzas = puisi.isi.trim().split(/\n\n+/);
const firstStanza = stanzas[0] ?? '';
const restStanzas = stanzas.slice(1);
const pageUrl    = Astro.url.href;

const wordCount  = puisi.isi.trim().split(/\s+/).length;
const readMins   = Math.max(1, Math.round(wordCount / 80));
const folio      = romanize(idx).toLowerCase();
const totalFolio = romanize(semua.length - 1).toLowerCase();
---

<Layout title={`${puisi.judul} — Chao Ivans`} description={puisi.pengantar ?? `Puisi karya Chao Ivans, dari lembaran ${folio}.`}>

  <!-- Reading progress as a thin gold ink line on top -->
  <div class="progress-track" aria-hidden="true">
    <div class="progress-bar" id="progress-bar"></div>
  </div>

  <Header />

  <!-- Vertical scroll progress as a vellum ink rail -->
  <aside class="scroll-rail" aria-hidden="true">
    <span class="rail-track"></span>
    <span class="rail-fill" id="rail-fill"></span>
    <span class="rail-folio">{folio}</span>
    <span class="rail-total">/ {totalFolio}</span>
  </aside>

  <main class="page">
    <article class="article" id="article">

      <!-- Ambient glows -->
      <div class="glow glow-a" aria-hidden="true"></div>
      <div class="glow glow-b" aria-hidden="true"></div>

      <!-- Manuscript header -->
      <header class="poem-head">
        <p class="folio-line" data-anim="folio">
          <span class="fl-mark">∽</span>
          <span class="fl-text">folio {folio} · puisi</span>
          <span class="fl-mark">∽</span>
        </p>

        <p class="date" data-anim="date">{formatTgl(puisi.tanggal)}</p>

        <h1 class="title" data-anim="title">{puisi.judul}</h1>

        <svg class="title-stroke" viewBox="0 0 400 16" aria-hidden="true">
          <path id="ts-path"
            d="M4 10 Q 80 2, 200 8 T 396 8"
            stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/>
        </svg>

        <p class="byline" data-anim="byline">
          <span>oleh <em>Chao Ivans</em></span>
          <span class="sep">·</span>
          <span>{readMins} menit baca</span>
        </p>

        {puisi.pengantar && (
          <p class="pengantar" data-anim="pengantar">
            <span class="pq-mark">“</span>
            {puisi.pengantar}
            <span class="pq-mark">”</span>
          </p>
        )}
      </header>

      <!-- Body -->
      <div class="body">

        <!-- First stanza: TypeIt animation, with drop cap -->
        <div class="stanza stanza-first">
          <p class="stanza-typed" id="first-stanza" data-raw={firstStanza}></p>
        </div>

        {restStanzas.map((p, i) => (
          <div class="stanza" data-stanza-index={i + 1}>
            <p class="stanza-text">{p}</p>
          </div>
        ))}

      </div>

      <!-- End mark -->
      <div class="end-mark" data-anim="endmark">
        <span class="em-orn" aria-hidden="true">∽ ∼ ∽</span>
        <p class="em-fin">— selesai —</p>
        <p class="em-meta">
          <span>𓁹 {puisi.views ?? 0} kali dibaca</span>
          <span class="dot">·</span>
          <span>{wordCount} kata</span>
        </p>
      </div>

      <!-- Share -->
      <section class="share" data-anim="share">
        <p class="share-label">— bagikan puisi ini —</p>
        <div class="share-row">
          <button class="sbtn" id="btn-native">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            Bagikan
          </button>
          <button class="sbtn" id="btn-copy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span id="copy-lbl">Salin Tautan</span>
          </button>
          <a class="sbtn sbtn-wa" href={`https://wa.me/?text=${encodeURIComponent(`"${puisi.judul}" — Chao Ivans\n${pageUrl}`)}`} target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.138.562 4.144 1.541 5.876L0 24l6.303-1.519A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.893 0-3.671-.497-5.214-1.366l-.374-.219-3.742.902.938-3.651-.24-.386A9.946 9.946 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            WhatsApp
          </a>
          <a class="sbtn sbtn-tw" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`"${puisi.judul}" — Chao Ivans`)}&url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.629 5.905-5.629zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X / Twitter
          </a>
        </div>
      </section>

      <!-- Page-turn navigation -->
      <nav class="pnav" data-anim="nav">
        {prev ? (
          <a href={`/puisi/${prev.slug}`} class="pnav-item pnav-prev">
            <span class="pnav-dir">← lembaran sebelumnya</span>
            <span class="pnav-title">{prev.judul}</span>
          </a>
        ) : <div />}
        <a href="/semua" class="pnav-all">
          <span class="pnav-orn">∽</span>
          <span>katalog</span>
          <span class="pnav-orn">∽</span>
        </a>
        {next ? (
          <a href={`/puisi/${next.slug}`} class="pnav-item pnav-next">
            <span class="pnav-dir">lembaran berikutnya →</span>
            <span class="pnav-title">{next.judul}</span>
          </a>
        ) : <div />}
      </nav>

    </article>
  </main>

  <Footer />
</Layout>

<script is:inline>
(function () {
  'use strict';

  const ready = () => new Promise(r => {
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', r);
    else r();
  });

  ready().then(init);

  function init () {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── Reading progress (top + side rail) ── */
    const bar  = document.getElementById('progress-bar');
    const rail = document.getElementById('rail-fill');
    const updateProgress = () => {
      const scrolled  = window.scrollY;
      const docH = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docH > 0 ? Math.min(1, scrolled / docH) : 0;
      if (bar)  bar.style.width  = (pct * 100) + '%';
      if (rail) rail.style.height = (pct * 100) + '%';
    };
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    if (!window.gsap) return;
    const gsap = window.gsap;
    gsap.registerPlugin(window.ScrollTrigger);

    /* ── Header reveal ── */
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.from('[data-anim="folio"]', { opacity: 0, y: 12, duration: 0.9 }, 0)
      .from('[data-anim="date"]',  { opacity: 0, y: 12, duration: 0.9 }, 0.15)
      .from('[data-anim="title"]', {
        opacity: 0, y: 40, filter: 'blur(16px)', duration: 1.4
      }, 0.3)
      .from('.title-stroke', { opacity: 0, duration: 0.4 }, 0.7);

    // Title brush stroke
    const tsPath = document.getElementById('ts-path');
    if (tsPath) {
      const len = tsPath.getTotalLength();
      gsap.set(tsPath, { strokeDasharray: len, strokeDashoffset: len });
      gsap.to(tsPath, { strokeDashoffset: 0, duration: 1.6, delay: 0.9, ease: 'power2.inOut' });
    }

    tl.from('[data-anim="byline"]', { opacity: 0, y: 12, duration: 0.8 }, 1.0);
    if (document.querySelector('[data-anim="pengantar"]')) {
      tl.from('[data-anim="pengantar"]', { opacity: 0, y: 16, duration: 1 }, 1.2);
    }

    /* ── First stanza: TypeIt with drop cap ── */
    const first = document.getElementById('first-stanza');
    if (first && window.TypeIt) {
      const raw = first.dataset.raw || '';
      first.textContent = '';
      // Wait until pengantar etc done (~2s)
      const startDelay = reduced ? 100 : 1900;
      new window.TypeIt(first, {
        speed: reduced ? 1 : 28,
        startDelay,
        cursor: false,
        lifeLike: true,
        afterComplete: (instance) => {
          // After typing done, wrap first letter for drop-cap
          applyDropCap(first);
        }
      }).type(raw.replace(/\n/g, '<br/>')).go();
    }

    function applyDropCap (el) {
      // Find first textual letter and wrap
      const html = el.innerHTML;
      const m = html.match(/^([\s\S]*?)([A-Za-zÀ-ÿ])/);
      if (!m) return;
      el.innerHTML = m[1] + '<span class="dropcap">' + m[2] + '</span>' + html.slice(m[0].length);
      const dc = el.querySelector('.dropcap');
      if (dc) gsap.from(dc, { opacity: 0, scale: 0.4, duration: 0.9, ease: 'back.out(1.6)' });
    }

    /* ── Subsequent stanzas: scroll wave ── */
    gsap.utils.toArray('.stanza:not(.stanza-first)').forEach((s, i) => {
      gsap.from(s, {
        opacity: 0, y: 40, filter: 'blur(8px)',
        duration: 1.2, ease: 'power3.out', delay: (i % 3) * 0.05,
        scrollTrigger: { trigger: s, start: 'top 88%' }
      });
    });

    /* ── End-mark, share, nav ── */
    gsap.from('[data-anim="endmark"] > *', {
      opacity: 0, y: 18, stagger: 0.15, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: '.end-mark', start: 'top 85%' }
    });
    gsap.from('[data-anim="share"] > *', {
      opacity: 0, y: 16, stagger: 0.1, duration: 0.9, ease: 'power3.out',
      scrollTrigger: { trigger: '.share', start: 'top 85%' }
    });
    gsap.from('[data-anim="nav"] > *', {
      opacity: 0, y: 16, stagger: 0.1, duration: 0.9, ease: 'power3.out',
      scrollTrigger: { trigger: '.pnav', start: 'top 90%' }
    });

    /* ── Glow parallax ── */
    gsap.to('.glow-a', { y: -100, x: 30, ease: 'none', scrollTrigger: { trigger: '.article', start: 'top top', end: 'bottom top', scrub: true } });
    gsap.to('.glow-b', { y:  100, x: -30, ease: 'none', scrollTrigger: { trigger: '.article', start: 'top top', end: 'bottom top', scrub: true } });

    /* ── Share button handlers ── */
    const url   = window.location.href;
    const title = document.querySelector('.title')?.textContent || '';
    const btnNative = document.getElementById('btn-native');
    if (navigator.share && btnNative) {
      btnNative.addEventListener('click', () => navigator.share({ title, url }).catch(() => {}));
    } else if (btnNative) {
      btnNative.style.display = 'none';
    }
    document.getElementById('btn-copy')?.addEventListener('click', () => {
      navigator.clipboard.writeText(url).then(() => {
        const lbl = document.getElementById('copy-lbl');
        if (lbl) {
          lbl.textContent = 'Tersalin!';
          setTimeout(() => (lbl.textContent = 'Salin Tautan'), 2000);
        }
      });
    });
  }
})();
</script>

<style>
  .page { padding-top: 0; }

  /* ── Top progress bar ── */
  .progress-track {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    z-index: 250;
    pointer-events: none;
    background: rgba(201,160,74,0.04);
  }
  .progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--gold-bright), var(--gold), transparent);
    box-shadow: 0 0 8px var(--gold-glow);
    transition: width 0.15s linear;
  }

  /* ── Side scroll rail ── */
  .scroll-rail {
    position: fixed;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 80;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    pointer-events: none;
  }
  .rail-track {
    width: 1px;
    height: 180px;
    background: var(--ink-line);
    position: relative;
  }
  .rail-fill {
    position: absolute;
    top: calc(50% - 90px + 26px);
    /* see right: rail-fill is layered inside rail using JS height */
  }
  /* better: compute fill inside the track */
  .scroll-rail { gap: 0.4rem; }
  .scroll-rail .rail-track {
    overflow: hidden;
  }
  .scroll-rail .rail-fill {
    position: absolute;
    top: 0; left: 0;
    width: 1px;
    height: 0%;
    background: linear-gradient(to bottom, var(--gold-bright), var(--gold));
    box-shadow: 0 0 6px var(--gold-glow);
    transition: height 0.15s linear;
  }
  .rail-folio {
    font-family: var(--display);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--gold);
  }
  .rail-total {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--vellum-ghost);
    letter-spacing: 0.18em;
  }
  @media (max-width: 980px) { .scroll-rail { display: none; } }

  /* ── Article ── */
  .article {
    position: relative;
    max-width: 640px;
    margin: 0 auto;
    padding: 8rem 1.5rem 5rem;
    overflow: clip;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .glow-a {
    width: 460px; height: 460px;
    background: radial-gradient(circle, rgba(201,160,74,0.16), transparent 65%);
    top: -100px; right: -200px;
  }
  .glow-b {
    width: 380px; height: 380px;
    background: radial-gradient(circle, rgba(168,84,64,0.12), transparent 65%);
    bottom: 10%; left: -250px;
  }

  /* ── Poem header ── */
  .poem-head {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 4rem;
  }
  .folio-line {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--vellum-ghost);
    margin-bottom: 1.4rem;
  }
  .fl-mark { color: var(--gold); opacity: 0.55; }
  .fl-text {
    font-family: var(--mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--gold);
    opacity: 0.85;
  }
  .date {
    font-family: var(--display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--vellum-mid);
    margin-bottom: 1.4rem;
    text-transform: lowercase;
  }
  .title {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    line-height: 1.05;
    color: var(--vellum);
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }
  .title-stroke {
    display: block;
    width: 70%;
    max-width: 360px;
    height: 16px;
    margin: 0.5rem auto 1.6rem;
    color: var(--gold);
    opacity: 0.85;
  }
  .byline {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
    font-family: var(--display);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--vellum-ghost);
  }
  .byline em {
    color: var(--gold-bright);
    font-style: italic;
    font-weight: 400;
  }
  .byline .sep { opacity: 0.5; }
  .pengantar {
    margin: 1.8rem auto 0;
    max-width: 50ch;
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    color: var(--vellum-dim);
    line-height: 1.75;
  }
  .pq-mark {
    color: var(--gold);
    opacity: 0.4;
    font-size: 1.4em;
    line-height: 0;
    vertical-align: -0.3em;
  }

  /* ── Body / stanzas ── */
  .body {
    position: relative;
    z-index: 1;
    margin-bottom: 4rem;
  }
  .stanza {
    margin-bottom: 2.6rem;
    font-family: var(--serif);
    font-size: 1.2rem;
    line-height: 2.05;
    color: var(--vellum);
    letter-spacing: 0.005em;
    will-change: transform, opacity, filter;
  }
  .stanza:last-child { margin-bottom: 0; }
  .stanza-text, .stanza-typed { white-space: pre-line; }
  .stanza-first {
    font-size: 1.25rem;
    color: var(--vellum);
  }

  /* drop cap (added by JS after typeit completes) */
  .stanza-first :global(.dropcap) {
    float: left;
    font-family: var(--display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3.2rem, 12vw, 4.6rem);
    line-height: 0.85;
    color: var(--gold);
    padding: 8px 12px 0 0;
    text-shadow: 0 0 22px rgba(201,160,74,0.25);
  }

  /* ── End mark ── */
  .end-mark {
    text-align: center;
    padding: 3rem 0 2rem;
  }
  .em-orn {
    display: block;
    color: var(--gold);
    opacity: 0.55;
    letter-spacing: 0.5em;
    margin-bottom: 0.8rem;
  }
  .em-fin {
    font-family: var(--display);
    font-style: italic;
    color: var(--vellum-mid);
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }
  .em-meta {
    font-family: var(--mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--vellum-ghost);
    display: inline-flex;
    gap: 0.7rem;
    align-items: baseline;
  }
  .em-meta .dot { opacity: 0.5; }

  /* ── Share ── */
  .share {
    margin: 2rem 0;
    padding: 1.5rem 1.4rem;
    border: 1px solid var(--ink-line);
    border-radius: 2px;
    background: linear-gradient(135deg, rgba(201,160,74,0.04), transparent 80%);
    text-align: center;
  }
  .share-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--gold);
    opacity: 0.75;
    margin-bottom: 1rem;
  }
  .share-row {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
  }
  .sbtn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--vellum-mid);
    background: var(--ink-raised);
    border: 1px solid var(--ink-line);
    border-radius: 2px;
    padding: 0.5rem 0.85rem;
    cursor: pointer;
    transition: color 0.3s ease, border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
    text-decoration: none;
  }
  .sbtn:hover {
    color: var(--gold-bright);
    border-color: var(--gold-soft);
    background: rgba(201,160,74,0.06);
    transform: translateY(-1px);
  }
  .sbtn-wa:hover { color: #25d366; border-color: rgba(37,211,102,0.4); }
  .sbtn-tw:hover { color: #ffffff; border-color: var(--vellum-mid); background: rgba(255,255,255,0.04); }

  /* ── Nav (page turn) ── */
  .pnav {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--ink-line);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
  }
  .pnav-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
