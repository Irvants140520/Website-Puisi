---
import Layout  from '../layouts/Layout.astro';
import Header  from '../components/Header.astro';
import Footer  from '../components/Footer.astro';
import { getAllPuisi } from '../lib/supabase.js';

const semua = await getAllPuisi();
const total = semua.length;
const startedYear = 2019;
const currentYear = new Date().getFullYear();
const yearsWriting = currentYear - startedYear;
---

<Layout title="Tentang — Chao Ivans" description="Tentang Chao Ivans, penulis Ruang Ivans.">
  <Header currentPath="/tentang" />

  <main class="page">

    <!-- ── Intro ── -->
    <section class="intro">
      <p class="kicker" data-anim="kicker">— tentang penulis</p>
      <h1 class="title" data-anim="title">Chao Ivans</h1>
      <!-- <p class="role" data-anim="role">— penulis · sejak {startedYear}</p> -->

      <div class="portrait" data-anim="portrait">
        <img
          src="/chaoivans.jpg"
          alt="Chao Ivans"
          width="580"
          height="580"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <!-- ── Body letter ── -->
    <section class="body">
      <p data-anim="paragraph">
        Namaku <em>Chao Ivans</em>,
        <br/> seorang yang menulis bukan karena ia benar & paham akan sesuatu,
        <br/> melainkan karena ingin mengerti dan ingin melihat kebodohannya sendiri. 
        <br/> Setiap baris yang tersusun, lahir
        dari ingatan yang nyaris luput: rintik hujan yang membasahi jendela, perbincangan antara bulan & bintang di langit temaram, dan percakapan yang tak sempat selesai, namun membekas.
      </p>
      <p data-anim="paragraph">
        Ruang ini adalah milik pribadi, tempat menyimpan apa yang berseliweran
        di dalam pikiran yang ribut. Tak semua perlu dimaknai. Beberapa ditulis hanya
        untuk berdiam sejenak, untuk merasakan sesuatu dengan lebih penuh, dan
        untuk menemukan bahasa bagi hal-hal yang selama ini tak terucapkan.
      </p>
      <p data-anim="paragraph">
        Aku percaya bahwa kata yang sederhana, jika ditata dengan jujur, dapat
        menyalakan lilin kecil yang hangat, di dalam ruang gelap seseorang. Itulah yang aku
        coba lakukan.
      </p>
      <p data-anim="paragraph">
        Terima kasih telah meluangkan
        waktu untuk singgah di lembaran-lembaran ini.
      </p>
    </section>

    <!-- ── Quote ── -->
    <section class="quote-sec">
      <blockquote class="quote">
        <p data-anim="quote">
          Membaca untuk mengenal dunia,<br/>
          <em>menulis untuk dikenal dunia.</em>
        </p>
      </blockquote>
    </section>

    <!-- ── Stats ── -->
    <section class="stats-sec">
      <div class="stats" data-anim="stats">
        <div><strong data-count={total}>{total}</strong><span>karya</span></div>
        <div><strong>{yearsWriting}</strong><span>tahun</span></div>
        <div><strong>id</strong><span>bahasa</span></div>
      </div>
    </section>

    <!-- ── Closing ── -->
    <section class="closing">
      <p data-anim="signature">salam hangat dari ruang sunyi,</p>
      <p class="sign" data-anim="signature">— Chao Ivans</p>
      <a href="/semua" class="cta" data-anim="cta">
        <span>baca seluruh karya</span>
        <svg viewBox="0 0 28 8" width="28" height="8"><path d="M0 4 H 24 M 21 1 L 24 4 L 21 7" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </section>

  </main>

  <Footer />
</Layout>

<script is:inline>
  (() => {
    const init = () => {
      if (!window.gsap) return;
      const gsap = window.gsap;
      if (window.ScrollTrigger) gsap.registerPlugin(window.ScrollTrigger);

      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.from('[data-anim="kicker"]',   { opacity: 0, y: 10, duration: 0.7 })
        .from('[data-anim="title"]',    { opacity: 0, y: 24, filter: 'blur(6px)', duration: 1.0 }, 0.1)
        .from('[data-anim="role"]',     { opacity: 0, y: 12, duration: 0.7 }, 0.4)
        .from('[data-anim="portrait"]', { opacity: 0, scale: 0.94, filter: 'blur(8px)', duration: 1.2 }, 0.5);

      if (!window.ScrollTrigger) return;

      // body paragraphs — word reveal on scroll (kept from before)
      gsap.utils.toArray('.body p').forEach((p) => {
        if (window.SplitType) {
          const split = new window.SplitType(p, { types: 'words' });
          gsap.set(split.words, { opacity: 0.18 });
          gsap.to(split.words, {
            opacity: 1, stagger: 0.025, duration: 0.6, ease: 'power2.out',
            scrollTrigger: { trigger: p, start: 'top 80%', end: 'top 35%', scrub: 1 }
          });
        } else {
          gsap.from(p, { opacity: 0, y: 20, duration: 0.9, scrollTrigger: { trigger: p, start: 'top 85%' } });
        }
      });

      gsap.from('[data-anim="quote"]', {
        opacity: 0, y: 24, filter: 'blur(6px)', duration: 1.1, ease: 'power3.out',
        scrollTrigger: { trigger: '.quote-sec', start: 'top 75%' }
      });

      gsap.from('[data-anim="stats"] > *', {
        opacity: 0, y: 14, stagger: 0.08, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: '.stats-sec', start: 'top 82%' }
      });

      document.querySelectorAll('[data-count]').forEach((el) => {
        const target = parseInt(el.dataset.count, 10);
        if (!Number.isFinite(target)) return;
        gsap.fromTo(el, { textContent: 0 }, {
          textContent: target,
          duration: 1.4, ease: 'power2.out',
          snap: { textContent: 1 },
          scrollTrigger: { trigger: '.stats-sec', start: 'top 80%' },
          onUpdate: function () { el.textContent = Math.round(this.targets()[0].textContent || 0); }
        });
      });

      gsap.from('[data-anim="signature"]', {
        opacity: 0, y: 14, stagger: 0.15, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: '.closing', start: 'top 82%' }
      });
      gsap.from('[data-anim="cta"]', {
        opacity: 0, y: 14, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: '.closing', start: 'top 78%' }
      });
    };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>

<style>
  .page { padding-top: 0; }

  /* ── Intro ── */
  .intro {
    max-width: 640px;
    margin: 0 auto;
    padding: 8.5rem 1.5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }
  .kicker {
    font-family: var(--ui);
    font-size: 0.62rem;
    letter-spacing: 0.4em;
    text-indent: 0.4em;
    text-transform: uppercase;
    color: var(--copper);
  }
  .title {
    font-family: var(--display);
    font-weight: 380;
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    background: linear-gradient(180deg, var(--paper) 0%, var(--copper-bright) 100%);
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .role {
    font-family: var(--display);
    font-style: italic;
    color: var(--paper-mid);
    font-size: 1rem;
  }
  .portrait {
    margin-top: 1.4rem;
    width: 168px;
    height: 168px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(198,148,112,0.35);
    box-shadow: 0 0 0 6px rgba(198,148,112,0.05);
  }
  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(15%) contrast(1.05);
    transition: filter 0.6s ease;
  }
  .portrait:hover img { filter: grayscale(0%) contrast(1.05); }

  /* ── Body ── */
  .body {
    max-width: 60ch;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .body p {
    font-family: var(--serif);
    font-size: 1.08rem;
    line-height: 1.95;
    color: var(--paper-mid);
  }
  .body p em {
    font-style: italic;
    color: var(--copper-bright);
  }

  /* ── Quote ── */
  .quote-sec {
    padding: 3rem 1.5rem;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .quote p {
    font-family: var(--display);
    font-weight: 350;
    font-size: clamp(1.4rem, 3.6vw, 2.2rem);
    line-height: 1.5;
    color: var(--paper);
    letter-spacing: -0.012em;
  }
  .quote p em {
    font-style: italic;
    color: var(--copper-bright);
    font-weight: 380;
  }

  /* ── Stats ── */
  .stats-sec {
    padding: 2rem 1.5rem;
    max-width: 640px;
    margin: 0 auto;
  }
  .stats {
    display: flex;
    justify-content: center;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 1.6rem 2.4rem;
    border-top: 1px solid rgba(198,148,112,0.16);
    border-bottom: 1px solid rgba(198,148,112,0.16);
    padding: 1.8rem 0;
  }
  .stats > div {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .stats strong {
    font-family: var(--display);
    font-style: italic;
    font-weight: 400;
    font-size: 2rem;
    color: var(--copper-bright);
    line-height: 1;
  }
  .stats span {
    font-family: var(--ui);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    text-indent: 0.32em;
    color: var(--paper-dim);
  }

  /* ── Closing ── */
  .closing {
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .closing p {
    font-family: var(--display);
    font-style: italic;
    color: var(--paper-mid);
    font-size: 1.05rem;
  }
  .sign {
    font-size: 1.4rem !important;
    color: var(--paper) !important;
    margin-bottom: 1.6rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 0.6rem;
    padding: 0.9rem 1.6rem;
    border: 1px solid rgba(198,148,112,0.5);
    color: var(--paper);
    font-family: var(--ui);
    font-weight: 500;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    transition:
      background 0.4s ease,
      border-color 0.4s ease,
      color 0.4s ease,
      gap 0.5s var(--ease-poetic);
  }
  .cta:hover {
    background: rgba(198,148,112,0.10);
    border-color: var(--copper-bright);
    color: var(--copper-bright);
    gap: 1.2rem;
  }

  /* ── Mobile ── */
  @media (max-width: 720px) {
    .intro { padding: 7rem 1.1rem 1.6rem; }
    .portrait { width: 140px; height: 140px; }
    .body { padding: 2.4rem 1.1rem; gap: 1.4rem; }
    .body p { font-size: 1rem; line-height: 1.85; }
    .quote-sec { padding: 2.4rem 1.1rem; }
    .stats-sec { padding: 1.6rem 1.1rem; }
    .stats { gap: 1.2rem 1.6rem; padding: 1.4rem 0; }
    .stats strong { font-size: 1.7rem; }
    .closing { padding: 3.2rem 1.1rem 2rem; }
  }
</style>
